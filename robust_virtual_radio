#!/bin/sh
#
# Kuruka RVR Tool v0.4
# Multi-stream L2 bridge between GCS and Aircraft over Tailscale
# Replaces tinc with tap2tcp for per-flow multi-stream tunneling
# Supports full 1500 MTU for device compatibility (cameras, etc.)
#
# Usage: rvr <command> [options]
#

set -e

#############################################
# LOGGING
#############################################
SETUP_LOG="/tmp/rvr-setup.log"

# Initialize log file for setup commands
init_setup_log() {
    # Truncate if over 1MB to prevent /tmp (tmpfs/RAM) exhaustion
    [ -f "$SETUP_LOG" ] && [ "$(wc -c < "$SETUP_LOG" 2>/dev/null || echo 0)" -gt 1048576 ] && : > "$SETUP_LOG"
    exec > >(tee -a "$SETUP_LOG") 2>&1
    echo ""
    echo "========================================="
    echo "  RVR Setup Log - $(date)"
    echo "========================================="
}

# Log a command and its output (for debugging)
log_cmd() {
    local desc="$1"
    shift
    echo "[CMD] $desc: $*"
    "$@" 2>&1 || echo "[CMD] Command failed with exit code: $?"
}

#############################################
# CONFIGURATION
#############################################
KCPTUN_PORT="4000"
KCPTUN_LOCAL_PORT="4001"
TAP2TCP_PORT="655"
KCPTUN_KEY="KurukaRVRKey2024"
NETWORK_NAME="rvr_bridge"
TAP2TCP_BINARY="/usr/bin/tap2tcp"

# MTU Configuration
BRIDGE_MTU="1500"
KCP_SEGMENT_MTU="1200"
KCP_SOCKBUF="8388608"
KCP_SMUXBUF="8388608"
KCP_SMUXVER=2
KCP_STREAM_BUF="2097152"

# KCP ARQ tuning — optimized for Starlink drop pattern (100-500ms outage, then full recovery)
KCP_NODELAY=1
KCP_INTERVAL=20
KCP_RESEND=4
KCP_NC=1

# Timing configuration
TAILSCALE_WAIT_TIMEOUT=120
TAILSCALE_CHECK_INTERVAL=5
KCPTUN_SETTLE_TIME=3
SERVICE_RESTART_DELAY=5
HEALTH_CHECK_INTERVAL=30
STP_TIMEOUT=45

STATE_FILE="/etc/rvr.conf"
HEALTH_FILE="/tmp/rvr.health"
STATS_FILE="/tmp/tap2tcp.stats"
SSH_KEY="/root/.ssh/id_dropbear"
SSH_PUBKEY="/root/.ssh/id_dropbear.pub"

#############################################
# OPKG FEED SETUP
#############################################
OPKG_FEED_SETUP_SCRIPT='
    # Ensure both arch variants are registered (GL-A1300 only has base arch)
    if ! grep -q "arch aarch64_cortex-a53_neon-vfpv4 " /etc/opkg.conf 2>/dev/null; then
        echo "arch aarch64_cortex-a53_neon-vfpv4 10" >> /etc/opkg.conf
    fi
    if ! grep -q "arch aarch64_cortex-a53 " /etc/opkg.conf 2>/dev/null; then
        echo "arch aarch64_cortex-a53 9" >> /etc/opkg.conf
    fi
    if ! grep -q "arch all " /etc/opkg.conf 2>/dev/null; then
        echo "arch all 1" >> /etc/opkg.conf
    fi

    RELEASE=$(. /etc/openwrt_release 2>/dev/null; echo "$DISTRIB_RELEASE")
    case "$RELEASE" in
        *SNAPSHOT*) FEED_VER="23.05.5" ;;
        [0-9]*) FEED_VER="$RELEASE" ;;
        *) FEED_VER="23.05.5" ;;
    esac

    FEED_URL="https://downloads.openwrt.org/releases/${FEED_VER}/packages/aarch64_cortex-a53/packages"
    FEEDS_FILE="/etc/opkg/customfeeds.conf"

    if ! grep -q "openwrt_packages" "$FEEDS_FILE" 2>/dev/null; then
        echo "src/gz openwrt_packages $FEED_URL" >> "$FEEDS_FILE"
    fi
'

ensure_opkg_feeds() {
    ( eval "$OPKG_FEED_SETUP_SCRIPT" )
}

ensure_opkg_feeds_remote() {
    local ip="$1"
    ssh_aircraft "$ip" "$OPKG_FEED_SETUP_SCRIPT"
}

#############################################
# PACKAGE INSTALLATION
#############################################
_get_pkg_dir() {
    local script_dir
    script_dir=$(cd "$(dirname "$0")" && pwd)
    echo "$script_dir/packages"
}

ensure_pkg_local() {
    local binary="$1" package="$2" subdir="${3:-common}"
    command -v "$binary" >/dev/null 2>&1 && return 0

    local pkg_dir
    pkg_dir=$(_get_pkg_dir)

    if ls "$pkg_dir/$subdir/${package}_"*.ipk >/dev/null 2>&1; then
        opkg install "$pkg_dir/$subdir/${package}_"*.ipk --force-depends 2>&1 | grep -vE "has no valid architecture|Configuring" || true
    fi

    command -v "$binary" >/dev/null 2>&1 && return 0

    echo "    Falling back to opkg feeds for $package..."
    opkg update >/dev/null 2>&1 || true
    opkg install "$package" >/dev/null 2>&1 || true

    command -v "$binary" >/dev/null 2>&1
}

# Install tap2tcp binary from bundled packages
ensure_tap2tcp_local() {
    [ -x "$TAP2TCP_BINARY" ] && return 0

    local pkg_dir
    pkg_dir=$(_get_pkg_dir)

    if [ -f "$pkg_dir/common/tap2tcp-aarch64" ]; then
        cp "$pkg_dir/common/tap2tcp-aarch64" "$TAP2TCP_BINARY"
        chmod +x "$TAP2TCP_BINARY"
        echo "    tap2tcp binary installed."
    else
        echo "    ERROR: tap2tcp binary not found in $pkg_dir/common/"
        return 1
    fi

    [ -x "$TAP2TCP_BINARY" ]
}

ensure_packages_local() {
    local role="$1"
    local pkg_dir
    pkg_dir=$(_get_pkg_dir)

    local need_install=""
    [ -x "$TAP2TCP_BINARY" ] || need_install=1
    case "$role" in
        gcs)      command -v kcptun-server >/dev/null 2>&1 || need_install=1 ;;
        aircraft)  command -v kcptun-client >/dev/null 2>&1 || need_install=1 ;;
    esac

    [ -z "$need_install" ] && { echo "    Packages already installed."; return 0; }

    # Install tap2tcp binary
    ensure_tap2tcp_local

    # Install .ipk packages
    if [ -d "$pkg_dir/common" ]; then
        opkg install "$pkg_dir/common/"*.ipk --force-depends 2>&1 | grep -vE "has no valid architecture|Configuring|tap2tcp" || true
        case "$role" in
            gcs)
                [ -d "$pkg_dir/gcs" ] && opkg install "$pkg_dir/gcs/"*.ipk --force-depends 2>&1 | grep -vE "has no valid architecture|Configuring" || true
                ;;
            aircraft)
                [ -d "$pkg_dir/aircraft" ] && opkg install "$pkg_dir/aircraft/"*.ipk --force-depends 2>&1 | grep -vE "has no valid architecture|Configuring" || true
                ;;
        esac
    fi

    # Verify
    local missing=""
    [ -x "$TAP2TCP_BINARY" ] || missing="tap2tcp $missing"
    case "$role" in
        gcs)      command -v kcptun-server >/dev/null 2>&1 || missing="kcptun-server $missing" ;;
        aircraft)  command -v kcptun-client >/dev/null 2>&1 || missing="kcptun-client $missing" ;;
    esac

    if [ -n "$missing" ]; then
        echo "    Bundled packages incomplete, falling back to opkg feeds..."
        opkg update >/dev/null 2>&1 || true
        for pkg in $missing; do
            [ "$pkg" = "tap2tcp" ] && continue  # tap2tcp is not an opkg package
            opkg install "$pkg" >/dev/null 2>&1 || true
        done
    fi

    # Final verification
    local still_missing=""
    [ -x "$TAP2TCP_BINARY" ] || still_missing="tap2tcp $still_missing"
    case "$role" in
        gcs)      command -v kcptun-server >/dev/null 2>&1 || still_missing="kcptun-server $still_missing" ;;
        aircraft)  command -v kcptun-client >/dev/null 2>&1 || still_missing="kcptun-client $still_missing" ;;
    esac
    if [ -n "$still_missing" ]; then
        log_error "Required packages still missing: $still_missing"
        exit 1
    fi
}

ensure_packages_remote() {
    local ip="$1"

    local remote_check=$(ssh_aircraft "$ip" '
        l=0; k=0
        [ -x /usr/bin/tap2tcp ] && l=1
        command -v kcptun-client >/dev/null 2>&1 && k=1
        echo "${l}${k}"
    ' 2>/dev/null | tr -d ' \t\n\r')
    if [ "$remote_check" = "11" ]; then
        echo "    Packages already installed on aircraft."
        return 0
    fi

    local script_dir=$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")
    local pkg_dir=""
    for d in "$script_dir/packages" "/root/RVR_v0.4/packages"; do
        [ -d "$d/common" ] && { pkg_dir="$d"; break; }
    done

    if [ -n "$pkg_dir" ]; then
        # Copy tap2tcp binary first
        echo "    Copying tap2tcp binary to aircraft..."
        cat "$pkg_dir/common/tap2tcp-aarch64" | dbclient -i "$SSH_KEY" -y root@"$ip" "cat > /usr/bin/tap2tcp && chmod +x /usr/bin/tap2tcp" 2>/dev/null

        # Copy .ipk packages
        local pkg_count=$(find "$pkg_dir/common" "$pkg_dir/aircraft" -name '*.ipk' 2>/dev/null | wc -l)
        if [ "$pkg_count" -gt 0 ]; then
            echo "    Copying $pkg_count packages to aircraft..."
            local tmp_tar="/tmp/rvr-packages.tar"
            tar -cf "$tmp_tar" -C "$pkg_dir" common aircraft 2>/dev/null
            ssh_aircraft "$ip" "rm -rf /tmp/rvr-packages; mkdir -p /tmp/rvr-packages" 2>/dev/null
            cat "$tmp_tar" | dbclient -i "$SSH_KEY" -y root@"$ip" "tar -xf - -C /tmp/rvr-packages" 2>/dev/null
            rm -f "$tmp_tar"

            echo "    Installing packages on aircraft..."
            ssh_aircraft "$ip" '
                if ls /tmp/rvr-packages/common/*.ipk >/dev/null 2>&1; then
                    opkg install /tmp/rvr-packages/common/*.ipk /tmp/rvr-packages/aircraft/*.ipk \
                        --force-depends 2>&1 | grep -vE "has no valid architecture|Configuring" || true
                fi
                rm -rf /tmp/rvr-packages
            '
        fi
        echo "    Packages installed."
    fi

    # Verify
    ssh_aircraft "$ip" '
        missing=""
        [ -x /usr/bin/tap2tcp ] || missing="tap2tcp $missing"
        command -v kcptun-client >/dev/null 2>&1 || missing="kcptun-client $missing"

        if [ -n "$missing" ]; then
            echo "    Falling back to opkg feeds..."
            opkg update >/dev/null 2>&1 || true
            for pkg in $missing; do
                [ "$pkg" = "tap2tcp" ] && continue
                opkg install "$pkg" >/dev/null 2>&1 || true
            done
        fi

        [ -x /usr/bin/tap2tcp ] && command -v kcptun-client >/dev/null 2>&1 || {
            echo "ERROR: Required packages missing on aircraft"
            exit 1
        }
    '
}

