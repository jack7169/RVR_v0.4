log_msg() {
    local level="$1"
    local msg="$2"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[$timestamp] [$level] $msg"
    logger -t rvr -p "daemon.$level" "$msg" 2>/dev/null || true
}

log_info() { log_msg "info" "$1"; }
log_warn() { log_msg "warn" "$1"; }
log_error() { log_msg "err" "$1"; }

get_tailscale_ip_nowait() {
    tailscale ip -4 2>/dev/null | head -1
}

get_local_tailscale_ip() {
    local ip=$(get_tailscale_ip_nowait)
    if [ -z "$ip" ]; then
        echo "ERROR: Could not get Tailscale IP. Is Tailscale running?" >&2
        exit 1
    fi
    echo "$ip"
}

wait_for_tailscale() {
    local timeout="${1:-$TAILSCALE_WAIT_TIMEOUT}"
    local elapsed=0

    log_info "Waiting for Tailscale (timeout: ${timeout}s)..."

    while [ $elapsed -lt $timeout ]; do
        if tailscale status >/dev/null 2>&1; then
            local ip=$(get_tailscale_ip_nowait)
            if [ -n "$ip" ]; then
                log_info "Tailscale ready with IP: $ip"
                return 0
            fi
        fi
        sleep $TAILSCALE_CHECK_INTERVAL
        elapsed=$((elapsed + TAILSCALE_CHECK_INTERVAL))
    done

    log_error "Tailscale not ready after ${timeout}s"
    return 1
}

is_tailscale_ready() {
    tailscale status >/dev/null 2>&1 && [ -n "$(get_tailscale_ip_nowait)" ]
}

# Wait for L2 bridge to reach forwarding state (STP convergence)
# Polls bridge port state every 2s instead of hard-coded sleep.
# Returns 0 on success, 1 on timeout.
wait_for_bridge() {
    local timeout="${1:-$STP_TIMEOUT}"
    local elapsed=0

    log_info "Waiting for bridge convergence (max ${timeout}s)..."

    while [ $elapsed -lt $timeout ]; do
        # Check if rvr interface exists and is in forwarding state
        if ip link show rvr_bridge >/dev/null 2>&1; then
            local state
            state=$(cat /sys/class/net/rvr_bridge/brport/state 2>/dev/null)
            # Bridge port states: 0=disabled, 1=listening, 2=learning, 3=forwarding
            if [ "$state" = "3" ]; then
                log_info "Bridge forwarding after ${elapsed}s"
                # Sync connection timestamp to both sides
                local conn_ts=$(date +%s)
                echo "$conn_ts" > /tmp/rvr.connected
                local peer_ip=$(get_aircraft_ip 2>/dev/null)
                [ -n "$peer_ip" ] && ssh_aircraft "$peer_ip" "echo $conn_ts > /tmp/rvr.connected" 2>/dev/null || true
                return 0
            fi
            # If STP is disabled, port goes straight to forwarding (state file may not exist)
            if [ ! -f /sys/class/net/rvr_bridge/brport/state ]; then
                # No STP state file — check if interface is UP and in bridge
                if bridge link show dev rvr_bridge 2>/dev/null | grep -q "state"; then
                    log_info "Bridge ready after ${elapsed}s (no STP)"
                    local conn_ts=$(date +%s)
                    echo "$conn_ts" > /tmp/rvr.connected
                    local peer_ip=$(get_aircraft_ip 2>/dev/null)
                    [ -n "$peer_ip" ] && ssh_aircraft "$peer_ip" "echo $conn_ts > /tmp/rvr.connected" 2>/dev/null || true
                    return 0
                fi
            fi
        fi
        sleep 2
        elapsed=$((elapsed + 2))
        [ $((elapsed % 10)) -eq 0 ] && log_info "Bridge convergence: ${elapsed}s elapsed..."
    done

    log_warn "Bridge convergence timeout after ${timeout}s"
    return 1
}

resolve_aircraft() {
    local input="$1"
    [ -z "$input" ] && return
    echo "$input" | grep -qE '^100\.' && { echo "$input"; return; }
    local aircraft_file="/etc/rvr/aircraft.json"
    [ -f "$aircraft_file" ] || return
    local ip=$(awk -v id="$input" '
        /"'"$input"'"[[:space:]]*:/ { found=1 }
        found && /"tailscale_ip"/ { gsub(/.*"tailscale_ip"[[:space:]]*:[[:space:]]*"/, ""); gsub(/".*/, ""); print; exit }
    ' "$aircraft_file")
    if [ -n "$ip" ]; then echo "$ip"; return; fi
    ip=$(awk -v name="$input" '
        BEGIN { IGNORECASE=1 }
        /"name"[[:space:]]*:/ {
            n=$0; gsub(/.*"name"[[:space:]]*:[[:space:]]*"/, "", n); gsub(/".*/, "", n)
            if (tolower(n) == tolower(name)) found=1
        }
        found && /"tailscale_ip"/ { gsub(/.*"tailscale_ip"[[:space:]]*:[[:space:]]*"/, ""); gsub(/".*/, ""); print; exit }
    ' "$aircraft_file")
    [ -n "$ip" ] && echo "$ip"
}

get_aircraft_ip() {
    if [ -n "$1" ]; then
        local resolved=$(resolve_aircraft "$1")
        if [ -n "$resolved" ]; then
            echo "$resolved"
        else
            echo "$1"
        fi
    elif [ -f "$STATE_FILE" ]; then
        . "$STATE_FILE"
        echo "${AIRCRAFT_IP:-}"
    fi
}

require_aircraft_ip() {
    local ip=$(get_aircraft_ip "$1")
    if [ -z "$ip" ]; then
        echo "ERROR: Aircraft IP required."
        exit 1
    fi
    echo "$ip"
}

save_aircraft_ip() {
    echo "AIRCRAFT_IP=\"$1\"" > "$STATE_FILE"
}

save_aircraft_profile() {
    local name="$1"
    local ip="$2"
    local explicit_id="${3:-}"
    local aircraft_file="/etc/rvr/aircraft.json"

    mkdir -p /etc/rvr

    local id
    if [ -n "$explicit_id" ]; then
        id="$explicit_id"
    else
        id=$(printf '%s' "$name" | tr 'A-Z' 'a-z' | sed 's/[^-a-z0-9_]/-/g; s/--*/-/g; s/^-//; s/-$//')
        [ -z "$id" ] && id="aircraft-$(echo "$ip" | tr '.' '-')"
    fi

    local created=$(date -Iseconds 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S')

    if [ ! -f "$aircraft_file" ]; then
        printf '{\n  "version": 1,\n  "active": "",\n  "profiles": {}\n}\n' > "$aircraft_file"
    fi

    local tmp_profiles=$(mktemp)
    awk '
    /"[a-zA-Z0-9_-]+":[[:space:]]*\{/ {
        pid = $0
        sub(/^[^"]*"/, "", pid)
        sub(/".*/, "", pid)
        if (pid != "profiles") {
            current_id = pid
            p_pass[current_id] = ""
        }
    }
    current_id && /"name":/ {
        val = $0; sub(/.*"name":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_name[current_id] = val
    }
    current_id && /"tailscale_ip":/ {
        val = $0; sub(/.*"tailscale_ip":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_ip[current_id] = val
    }
    current_id && /"ssh_password":/ {
        val = $0; sub(/.*"ssh_password":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_pass[current_id] = val
    }
    current_id && /"created":/ {
        val = $0; sub(/.*"created":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_created[current_id] = val
    }
    current_id && /"last_used":/ {
        val = $0; sub(/.*"last_used":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_last[current_id] = val
        print current_id "|" p_name[current_id] "|" p_ip[current_id] "|" p_pass[current_id] "|" p_created[current_id] "|" p_last[current_id]
    }
    ' "$aircraft_file" > "$tmp_profiles"

    local found=0
    local tmp_updated=$(mktemp)
    while IFS='|' read -r pid pname pip ppass pcreated plast; do
        [ -z "$pid" ] && continue
        if [ "$pid" = "$id" ] || [ "$pip" = "$ip" ]; then
            echo "$id|$name|$ip|$ppass|$pcreated|$created"
            found=1
        else
            echo "$pid|$pname|$pip|$ppass|$pcreated|$plast"
        fi
    done < "$tmp_profiles" > "$tmp_updated"

    if [ "$found" = "0" ]; then
        echo "$id|$name|$ip||$created|$created" >> "$tmp_updated"
    fi

    printf '{\n  "version": 1,\n  "active": "%s",\n  "profiles": {\n' "$id" > "$aircraft_file"

    local first=1
    while IFS='|' read -r pid pname pip ppass pcreated plast; do
        [ -z "$pid" ] && continue
        [ $first -eq 0 ] && printf ',\n' >> "$aircraft_file"
        printf '    "%s": {\n' "$pid" >> "$aircraft_file"
        printf '      "name": "%s",\n' "$pname" >> "$aircraft_file"
        printf '      "tailscale_ip": "%s",\n' "$pip" >> "$aircraft_file"
        printf '      "ssh_password": "%s",\n' "$ppass" >> "$aircraft_file"
        printf '      "created": "%s",\n' "$pcreated" >> "$aircraft_file"
        printf '      "last_used": "%s"\n' "$plast" >> "$aircraft_file"
        printf '    }' >> "$aircraft_file"
        first=0
    done < "$tmp_updated"

    printf '\n  }\n}\n' >> "$aircraft_file"
    rm -f "$tmp_profiles" "$tmp_updated"

    echo "[*] Aircraft profile '$name' ($id) saved and set active."
}

check_aircraft_reachable() {
    ping -c 1 -W 5 "$1" > /dev/null 2>&1
}

ensure_ssh_key() {
    if [ ! -f "$SSH_KEY" ]; then
        echo "[*] Generating SSH key..."
        mkdir -p /root/.ssh
        chmod 700 /root/.ssh
        dropbearkey -t ed25519 -f "$SSH_KEY" >/dev/null 2>&1
        dropbearkey -y -f "$SSH_KEY" 2>/dev/null | grep "^ssh-" > "$SSH_PUBKEY"
    fi
}

setup_ssh_keys() {
    local ip="$1"
    local password="$2"
    ensure_ssh_key

    local pubkey=$(cat "$SSH_PUBKEY")
    local ssh_cmd="mkdir -p /etc/dropbear && echo '$pubkey' >> /etc/dropbear/authorized_keys && chmod 600 /etc/dropbear/authorized_keys && sort -u /etc/dropbear/authorized_keys -o /etc/dropbear/authorized_keys"

    if [ -n "$password" ]; then
        echo "[*] Installing SSH key on $ip (using stored password)..."
        if command -v sshpass >/dev/null 2>&1; then
            sshpass -p "$password" dbclient -y root@"$ip" "$ssh_cmd" 2>/dev/null
        else
            echo "    Installing sshpass..."
            ensure_pkg_local sshpass sshpass gcs
            if command -v sshpass >/dev/null 2>&1; then
                sshpass -p "$password" dbclient -y root@"$ip" "$ssh_cmd" 2>/dev/null
            else
                echo "    ERROR: sshpass not available. Please install SSH key manually."
                return 1
            fi
        fi
    else
        echo "[*] Installing SSH key on $ip (enter password once)..."
        dbclient -y root@"$ip" "$ssh_cmd"
    fi

    sleep 1
    local verify=$(dbclient -i "$SSH_KEY" -y root@"$ip" "echo keyauth_ok" </dev/null 2>/dev/null)
    if [ "$verify" = "keyauth_ok" ]; then
        echo "    SSH key installed successfully."
    else
        echo "    WARNING: Key verification inconclusive. Continuing..."
    fi
}

ssh_aircraft() {
    local ip="$1"; shift
    timeout 120 dbclient -i "$SSH_KEY" -y root@"$ip" "$@"
}

#############################################
# HEALTH CHECK FUNCTIONS
#############################################
check_local_health() {
    # Only check services that have been configured (init scripts exist)
    # If setup hasn't been run, there's nothing to check
    [ -f /etc/init.d/kcptun-server ] || [ -f /etc/init.d/kcptun-client ] || [ -f /etc/init.d/tap2tcp ] || return 0

    local issues=""
    is_tailscale_ready || issues="${issues}tailscale_down,"

    if [ -f /etc/init.d/kcptun-server ]; then
        pgrep -f kcptun-server > /dev/null 2>&1 || issues="${issues}kcptun_down,"
    elif [ -f /etc/init.d/kcptun-client ]; then
        pgrep -f kcptun-client > /dev/null 2>&1 || issues="${issues}kcptun_down,"
    fi

    [ -f /etc/init.d/tap2tcp ] && ! pgrep tap2tcp > /dev/null 2>&1 && issues="${issues}tap2tcp_down,"
    [ -f /etc/init.d/tap2tcp ] && ! ip link show rvr_bridge > /dev/null 2>&1 && issues="${issues}interface_missing,"

    [ -n "$issues" ] && { echo "${issues%,}"; return 1; }
    return 0
}

record_health() {
    cat > "$HEALTH_FILE" << EOF
LAST_CHECK="$(date '+%Y-%m-%d %H:%M:%S')"
STATUS="$1"
DETAILS="$2"
EOF
}

#############################################
# SERVICE MANAGEMENT
#############################################
start_local_services() {
    log_info "Starting local services..."

    if ! wait_for_tailscale; then
        log_error "Cannot start - Tailscale not available"
        return 1
    fi

    local GCS_IP=$(get_local_tailscale_ip)

    # Update kcptun config with current IP
    if [ -f /etc/kcptun/server.json ]; then
        sed -i "s|\"listen\": \"[^\"]*:|\"listen\": \"$GCS_IP:|g" /etc/kcptun/server.json
    fi

    /etc/init.d/kcptun-server start 2>/dev/null || true
    sleep $KCPTUN_SETTLE_TIME

    if ! pgrep -f kcptun-server > /dev/null 2>&1; then
        log_error "kcptun-server failed to start"
        return 1
    fi

    /etc/init.d/tap2tcp start 2>/dev/null || true
    sleep 2

    log_info "Local services started"
    return 0
}

start_aircraft_services() {
    local AIRCRAFT_IP="$1"
    local GCS_IP=$(get_local_tailscale_ip)

    log_info "Starting aircraft services on $AIRCRAFT_IP..."

    check_aircraft_reachable "$AIRCRAFT_IP" || { log_warn "Aircraft unreachable"; return 1; }

    ssh_aircraft "$AIRCRAFT_IP" "
        [ -f /etc/kcptun/client.json ] && sed -i 's|\"remoteaddr\": \"[^\"]*:|\"remoteaddr\": \"$GCS_IP:|g' /etc/kcptun/client.json
        /etc/init.d/kcptun-client start 2>/dev/null || true
        sleep 3
        /etc/init.d/tap2tcp start 2>/dev/null || true
    " 2>/dev/null || { log_warn "Could not start aircraft services"; return 1; }

    log_info "Aircraft services started"
}

stop_local_services() {
    log_info "Stopping local services..."
    /etc/init.d/tap2tcp stop 2>/dev/null || true
    /etc/init.d/kcptun-server stop 2>/dev/null || true
    # Cleanup in case tap2tcp-down didn't run
    nft delete table bridge rvr_filter 2>/dev/null || true
    ip link set rvr_bridge nomaster 2>/dev/null || true
    ip link del rvr_bridge 2>/dev/null || true
    # Revert STP to prevent netifd from tearing down br-lan
    ip link set br-lan type bridge stp_state 0 2>/dev/null || true
    iptables -D OUTPUT -o br-lan -p udp --dport 41641 -j DROP 2>/dev/null || true
    iptables -D OUTPUT -o br-lan -p udp --sport 41641 -j DROP 2>/dev/null || true
    iptables -D FORWARD -i rvr_bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
    iptables -D FORWARD -o rvr_bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
    iptables -D FORWARD -i rvr_bridge -p udp --sport 41641 -j DROP 2>/dev/null || true
    iptables -D FORWARD -o rvr_bridge -p udp --sport 41641 -j DROP 2>/dev/null || true
}

stop_aircraft_services() {
    local AIRCRAFT_IP="$1"
    log_info "Stopping aircraft services..."
    check_aircraft_reachable "$AIRCRAFT_IP" && ssh_aircraft "$AIRCRAFT_IP" '
        /etc/init.d/tap2tcp stop 2>/dev/null || true
        /etc/init.d/kcptun-client stop 2>/dev/null || true
        nft delete table bridge rvr_filter 2>/dev/null || true
        ip link set rvr_bridge nomaster 2>/dev/null || true
        ip link del rvr_bridge 2>/dev/null || true
        iptables -D OUTPUT -o br-lan -p udp --dport 41641 -j DROP 2>/dev/null || true
        iptables -D OUTPUT -o br-lan -p udp --sport 41641 -j DROP 2>/dev/null || true
        iptables -D FORWARD -i rvr_bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
        iptables -D FORWARD -o rvr_bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
        iptables -D FORWARD -i rvr_bridge -p udp --sport 41641 -j DROP 2>/dev/null || true
        iptables -D FORWARD -o rvr_bridge -p udp --sport 41641 -j DROP 2>/dev/null || true
    ' 2>/dev/null || true
}

#############################################
# MONITOR COMMAND
#############################################
cmd_monitor() {
    local daemon_mode=0
    [ "$1" = "--daemon" ] || [ "$1" = "-d" ] && daemon_mode=1
    local AIRCRAFT_IP=$(get_aircraft_ip)

    if [ $daemon_mode -eq 1 ]; then
        log_info "Starting monitor daemon"
        while true; do
            do_health_check "$AIRCRAFT_IP"
            sleep $HEALTH_CHECK_INTERVAL
        done
    else
        do_health_check "$AIRCRAFT_IP"
    fi
}

do_health_check() {
    local AIRCRAFT_IP="$1"
    local restart_needed=0
    local issues

    issues=$(check_local_health)
    local local_status=$?

    if [ $local_status -ne 0 ]; then
        log_warn "Health issues: $issues"

        case "$issues" in
            *tailscale_down*)
                log_warn "Tailscale down, waiting..."
                if wait_for_tailscale 60; then
                    restart_needed=1
                else
                    record_health "ERROR" "tailscale_down"
                    return 1
                fi
                ;;
            *kcptun_down*|*tap2tcp_down*|*interface_missing*)
                restart_needed=1
                ;;
        esac
    fi

    if [ $restart_needed -eq 1 ]; then
        log_info "Restarting local services..."
        stop_local_services
        sleep $SERVICE_RESTART_DELAY
        start_local_services
        record_health "RECOVERING" "restarted_local"
    fi

    sleep 5
    issues=$(check_local_health)
    if [ $? -eq 0 ]; then
        log_info "Health check: OK"
        record_health "OK" ""
        return 0
    else
        log_error "Health check: FAILED ($issues)"
        record_health "ERROR" "$issues"
        return 1
    fi
}

#############################################
# WATCHDOG INSTALL/REMOVE
#############################################
cmd_watchdog_install() {
    log_info "Installing watchdog..."

    cat > /etc/rvr-watchdog.sh << 'WATCHDOG'
#!/bin/sh
LOCK="/tmp/rvr-watchdog.lock"
LOG="/tmp/rvr-watchdog.log"

[ -f "$LOCK" ] && kill -0 $(cat "$LOCK") 2>/dev/null && exit 0
echo $$ > "$LOCK"
trap "rm -f $LOCK" EXIT

# Dynamic log rotation based on available space
FLASH_FREE_KB=$(df /overlay 2>/dev/null | tail -1 | awk '{print $4}')
TMP_USED_KB=$(du -sk /tmp/rvr* /tmp/kcptun* 2>/dev/null | awk '{s+=$1} END {print s+0}')

LOG_CAP=2097152    # 2MB default (generous history)
SNMP_CAP=2097152   # 2MB default

# Low space: aggressive rotation
if [ "${FLASH_FREE_KB:-999999}" -lt 20480 ]; then
    LOG_CAP=262144; SNMP_CAP=262144  # 256KB each
    logger -t rvr -p daemon.warn "Low flash: ${FLASH_FREE_KB}KB free"
fi
# Critical: emergency cleanup
if [ "${FLASH_FREE_KB:-999999}" -lt 5120 ]; then
    LOG_CAP=65536; SNMP_CAP=65536    # 64KB each
    rm -f /tmp/rvr-capture.pcap
    logger -t rvr -p daemon.err "CRITICAL: ${FLASH_FREE_KB}KB flash free"
fi

# Rotate logs
[ -f "$LOG" ] && [ "$(wc -c < "$LOG" 2>/dev/null || echo 0)" -gt "$LOG_CAP" ] && tail -50 "$LOG" > "$LOG.tmp" && mv "$LOG.tmp" "$LOG"

SNMP_LOG="/tmp/kcptun-snmp.log"
[ -f "$SNMP_LOG" ] && [ "$(wc -c < "$SNMP_LOG" 2>/dev/null || echo 0)" -gt "$SNMP_CAP" ] && tail -2000 "$SNMP_LOG" > "$SNMP_LOG.tmp" && mv "$SNMP_LOG.tmp" "$SNMP_LOG"

# Clean orphaned temp files (older than 1 hour)
find /tmp -name 'rvr-disc-*' -mmin +60 -delete 2>/dev/null
find /tmp -name 'rvr-logs-*.fifo' -mmin +60 -delete 2>/dev/null

# Kill orphaned log streaming processes (grep/tail from closed SSE connections)
for pid in $(pgrep -f "grep.*rvr\|tap2tcp\|kcptun" 2>/dev/null); do
    # Only kill if parent is init (orphaned)
    ppid=$(awk '/PPid/ {print $2}' /proc/$pid/status 2>/dev/null)
    [ "$ppid" = "1" ] && kill "$pid" 2>/dev/null
done

# Resource snapshot for diagnosing ~12hr brick pattern
PROCS=$(ls -d /proc/[0-9]* 2>/dev/null | wc -l)
FDS=$(find /proc/[0-9]*/fd -maxdepth 0 2>/dev/null | while read d; do ls "$d" 2>/dev/null | wc -l; done | awk '{s+=$1} END {print s+0}')
MEM_FREE=$(awk '/MemAvailable/ {print int($2/1024)}' /proc/meminfo 2>/dev/null)
TMP_KB=$(df /tmp 2>/dev/null | tail -1 | awk '{print $3}')
OVERLAY_KB=$(df /overlay 2>/dev/null | tail -1 | awk '{print $3}')
echo "[$(date '+%Y-%m-%d %H:%M:%S')] resources: procs=$PROCS fds=$FDS mem_free=${MEM_FREE}MB tmp=${TMP_KB}KB overlay=${OVERLAY_KB}KB" >> "$LOG"

/usr/bin/rvr monitor >> "$LOG" 2>&1

# Collect Starlink history (extends dish's 15-min buffer to 24h)
STARLINK_COLLECTOR=""
for d in /www/rvr/cgi-bin /root/RVR_v0.4/www/cgi-bin; do
    [ -f "$d/starlink_collector.py" ] && { STARLINK_COLLECTOR="$d/starlink_collector.py"; break; }
done
if [ -n "$STARLINK_COLLECTOR" ] && command -v python3 >/dev/null 2>&1; then
    GRPC_TOOLS=""
    for d in /root/RVR_v0.4/starlink-grpc-tools /opt/starnav/starlink-grpc-tools; do
        [ -f "$d/starlink_grpc.py" ] && { GRPC_TOOLS="$d"; break; }
    done
    [ -n "$GRPC_TOOLS" ] && PYTHONPATH="$GRPC_TOOLS" timeout 8 python3 "$STARLINK_COLLECTOR" 2>/dev/null
fi

[ -f "$LOG" ] && tail -100 "$LOG" > "$LOG.tmp" && mv "$LOG.tmp" "$LOG"
WATCHDOG
    chmod +x /etc/rvr-watchdog.sh

    if ! crontab -l 2>/dev/null | grep -q "rvr-watchdog"; then
        (crontab -l 2>/dev/null; echo "* * * * * /etc/rvr-watchdog.sh") | crontab -
    fi

    # Boot-time startup
    if [ -f /etc/rc.local ] && ! grep -q "rvr_bridge" /etc/rc.local; then
        sed -i '/^exit 0/d' /etc/rc.local
        cat >> /etc/rc.local << 'RCLOCAL'

# RVR auto-start
( sleep 60; timeout 30 /usr/bin/rvr monitor ) &
exit 0
RCLOCAL
    fi

    echo "Watchdog installed. View log: cat /tmp/rvr-watchdog.log"
}

cmd_watchdog_remove() {
    crontab -l 2>/dev/null | grep -v "rvr-watchdog" | crontab - 2>/dev/null || true
    rm -f /etc/rvr-watchdog.sh
    [ -f /etc/rc.local ] && sed -i '/RVR auto-start/,/^exit 0/d' /etc/rc.local
    log_info "Watchdog removed"
}

#############################################
# SETUP COMMAND
#############################################
cmd_setup() {
    local AIRCRAFT_IP="$1"
    local AIRCRAFT_NAME="$2"

    [ -z "$AIRCRAFT_IP" ] && { echo "ERROR: Usage: rvr setup <aircraft_ip> <aircraft_name>"; exit 1; }
    [ -z "$AIRCRAFT_NAME" ] && { echo "ERROR: Aircraft name required. Usage: rvr setup <aircraft_ip> <aircraft_name>"; exit 1; }

    local GCS_IP=$(get_local_tailscale_ip)

    init_setup_log

    echo "========================================="
    echo "  Kuruka RVR Setup v0.4"
    echo "========================================="
    echo "  GCS:      $GCS_IP"
    echo "  Aircraft: $AIRCRAFT_IP ($AIRCRAFT_NAME)"
    echo "========================================="
    echo ""

    # Pre-flight checks
    echo "[*] Pre-flight checks..."
    log_cmd "GCS bridge interfaces" ip link show type bridge
    log_cmd "GCS br-lan info" ip link show br-lan
    log_cmd "GCS bridge ports" bridge link show
    echo ""

    echo "[*] Testing connectivity..."
    check_aircraft_reachable "$AIRCRAFT_IP" || { echo "ERROR: Cannot reach aircraft"; exit 1; }
    echo "    Aircraft reachable."

    # Version compatibility check
    echo "[*] Checking aircraft version..."
    local aircraft_ver=$(ssh_aircraft "$AIRCRAFT_IP" "cat /etc/rvr/version 2>/dev/null || cat /etc/l2bridge/version 2>/dev/null || echo 'none'" 2>/dev/null | tr -d ' \t\n\r')
    local gcs_ver=$(cat /etc/rvr/version 2>/dev/null || echo 'none')

    # Detect pre-rename install (old l2bridge/l2tap binaries or config)
    local aircraft_has_old=$(ssh_aircraft "$AIRCRAFT_IP" '
        old=no
        [ -d /etc/l2bridge ] && old=yes
        [ -f /usr/bin/l2bridge ] && old=yes
        [ -f /usr/bin/l2tap ] && old=yes
        [ -f /etc/init.d/l2tap ] && old=yes
        echo $old
    ' 2>/dev/null | tr -d ' \t\n\r')
    if [ "$aircraft_has_old" = "yes" ]; then
        echo "    Aircraft has old l2bridge/l2tap install — cleaning..."
        ssh_aircraft "$AIRCRAFT_IP" '
            [ -f /etc/init.d/l2tap ] && /etc/init.d/l2tap stop 2>/dev/null
            [ -f /etc/init.d/l2tap ] && /etc/init.d/l2tap disable 2>/dev/null
            rm -f /etc/init.d/l2tap
            rm -rf /etc/l2bridge
            rm -f /etc/l2bridge.conf
            rm -f /usr/bin/l2tap /usr/bin/l2bridge
            rm -f /tmp/l2bridge* /tmp/l2tap*
            echo "    Old install cleaned."
        ' 2>/dev/null
    fi

    if [ "$aircraft_ver" = "$gcs_ver" ] && [ "$gcs_ver" != "none" ]; then
        echo "    Aircraft version: $aircraft_ver (matches GCS)"
    else
        echo "    Version mismatch: GCS=$gcs_ver Aircraft=$aircraft_ver"
        local gcs_branch=$(cat /etc/rvr/branch 2>/dev/null || echo "main")
        local gcs_repo=$(cat /etc/rvr/repo 2>/dev/null || echo "jack7169/RVR_v0.4")
        if ssh_aircraft "$AIRCRAFT_IP" "command -v rvr >/dev/null 2>&1" 2>/dev/null; then
            echo "    Updating aircraft via rvr update (branch: $gcs_branch)..."
            if ssh_aircraft "$AIRCRAFT_IP" "rvr update --branch $gcs_branch" 2>&1; then
                echo "    Update command completed."
            else
                log_warn "Aircraft update failed — continuing setup with mismatched version"
            fi
        else
            echo "    Aircraft has no RVR CLI — installing via install.sh..."
            local install_url="https://raw.githubusercontent.com/${gcs_repo}/${gcs_branch}/install.sh"
            if ssh_aircraft "$AIRCRAFT_IP" "wget -T 10 -qO /tmp/rvr-install.sh '$install_url'" 2>&1; then
                echo "    Downloaded install.sh, running on aircraft..."
                if ssh_aircraft "$AIRCRAFT_IP" "sh /tmp/rvr-install.sh --role aircraft --no-webui" 2>&1; then
                    echo "    Aircraft installation complete."
                    if [ "$gcs_branch" != "main" ]; then
                        echo "    Switching aircraft to branch: $gcs_branch..."
                        ssh_aircraft "$AIRCRAFT_IP" "rvr update --branch $gcs_branch" 2>&1 || true
                    fi
                else
                    log_warn "Aircraft install.sh failed — continuing setup with mismatched version"
                fi
            else
                log_warn "Aircraft cannot reach GitHub — continuing setup with mismatched version"
            fi
        fi

        # Re-check version after update attempt
        local aircraft_ver_new=$(ssh_aircraft "$AIRCRAFT_IP" \
            "cat /etc/rvr/version 2>/dev/null || echo 'none'" 2>/dev/null | tr -d ' \t\n\r')
        if [ "$aircraft_ver_new" = "$gcs_ver" ] && [ "$gcs_ver" != "none" ]; then
            echo "    Aircraft version after update: $aircraft_ver_new (matches GCS)"
        elif [ "$aircraft_ver" != "$aircraft_ver_new" ]; then
            log_warn "Aircraft version changed ($aircraft_ver -> $aircraft_ver_new) but doesn't match GCS ($gcs_ver)"
        else
            log_warn "Aircraft version unchanged after update: $aircraft_ver_new (GCS: $gcs_ver)"
            log_warn "Update may have failed — bridge may not function correctly"
        fi
    fi

    # Get password from existing profile
    local aircraft_password=""
    if [ -f "/etc/rvr/aircraft.json" ]; then
        aircraft_password=$(awk -v ip="$AIRCRAFT_IP" '
            BEGIN { in_profile=0; current_ip=""; current_pass="" }
            /"[a-zA-Z0-9_-]+":[[:space:]]*\{/ { in_profile=1; current_ip=""; current_pass="" }
            in_profile && /"tailscale_ip":/ {
                gsub(/.*"tailscale_ip":[[:space:]]*"/, ""); gsub(/".*/, "")
                current_ip = $0
            }
            in_profile && /"ssh_password":/ {
                gsub(/.*"ssh_password":[[:space:]]*"/, ""); gsub(/".*/, "")
                current_pass = $0
            }
            /\}/ {
                if (in_profile && current_ip == ip && current_pass != "") {
                    print current_pass
                    exit
                }
                in_profile = 0
            }
        ' /etc/rvr/aircraft.json 2>/dev/null)
    fi

    setup_ssh_keys "$AIRCRAFT_IP" "$aircraft_password" || exit 1

    echo "[*] Checking aircraft bridge configuration..."
    ssh_aircraft "$AIRCRAFT_IP" "ip link show type bridge; bridge link show" 2>/dev/null || echo "    (Could not query aircraft)"
    echo ""

    echo "[*] Aircraft pre-flight checks..."
    log_cmd "Aircraft bridges" ssh_aircraft "$AIRCRAFT_IP" "ip link show type bridge"
    log_cmd "Aircraft br-lan" ssh_aircraft "$AIRCRAFT_IP" "ip link show br-lan 2>/dev/null || ip link show | grep -E 'br-|bridge'"

    local aircraft_bridge=$(ssh_aircraft "$AIRCRAFT_IP" "ip link show type bridge | grep -oE '^[0-9]+: [^:]+' | head -1 | awk '{print \$2}'")
    aircraft_bridge="${aircraft_bridge:-br-lan}"
    echo "    Aircraft bridge detected: $aircraft_bridge"

    local gcs_bridge=$(ip link show type bridge | grep -oE '^[0-9]+: [^:]+' | head -1 | awk '{print $2}')
    gcs_bridge="${gcs_bridge:-br-lan}"
    echo "    GCS bridge detected: $gcs_bridge"

    echo "[*] Stopping existing services..."
    cmd_stop_internal "$AIRCRAFT_IP" 2>/dev/null || true

    # GCS SETUP
    echo "[GCS] Installing packages..."
    ensure_opkg_feeds
    ensure_packages_local gcs

    echo "[GCS] Configuring tap2tcp..."
    mkdir -p /etc/rvr /etc/kcptun

    # Generate tap2tcp-up script (runs after TAP creation)
    cat > /etc/rvr/tap2tcp-up << EOF
#!/bin/sh
ip link set rvr_bridge mtu $BRIDGE_MTU
ip link set rvr_bridge up
iptables -I OUTPUT -o $gcs_bridge -p udp --dport 41641 -j DROP
iptables -I OUTPUT -o $gcs_bridge -p udp --sport 41641 -j DROP
iptables -I FORWARD -i rvr_bridge -p udp --dport 41641 -j DROP
iptables -I FORWARD -o rvr_bridge -p udp --dport 41641 -j DROP
iptables -I FORWARD -i rvr_bridge -p udp --sport 41641 -j DROP
iptables -I FORWARD -o rvr_bridge -p udp --sport 41641 -j DROP
ip link set $gcs_bridge type bridge stp_state 1
ip link set rvr_bridge master $gcs_bridge
nft -f - <<'NFTEOF'
table bridge rvr_filter {
    chain forward {
        type filter hook forward priority 0; policy accept;
        iifname != "rvr_bridge" oifname != "rvr_bridge" accept
        ether type arp accept
        ether type ip ip daddr 10.0.0.0/8 accept
        ether type ip ip daddr 172.16.0.0/12 accept
        ether type ip ip daddr 192.168.0.0/16 accept
        ether type ip ip daddr 169.254.0.0/16 accept
        ether type ip ip daddr 224.0.0.0/4 accept
        ether type ip ip daddr 255.255.255.255 accept
        ether type ip6 ip6 daddr fe80::/10 accept
        ether type ip6 ip6 daddr ff00::/8 accept
        iifname "rvr_bridge" counter drop
        oifname "rvr_bridge" counter drop
    }
}
NFTEOF
EOF
    chmod +x /etc/rvr/tap2tcp-up

    # Generate tap2tcp-down script (runs before shutdown)
    cat > /etc/rvr/tap2tcp-down << EOF
#!/bin/sh
nft delete table bridge rvr_filter 2>/dev/null || true
ip link set rvr_bridge nomaster 2>/dev/null || true
iptables -D OUTPUT -o $gcs_bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
iptables -D OUTPUT -o $gcs_bridge -p udp --sport 41641 -j DROP 2>/dev/null || true
iptables -D FORWARD -i rvr_bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
iptables -D FORWARD -o rvr_bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
iptables -D FORWARD -i rvr_bridge -p udp --sport 41641 -j DROP 2>/dev/null || true
iptables -D FORWARD -o rvr_bridge -p udp --sport 41641 -j DROP 2>/dev/null || true
EOF
    chmod +x /etc/rvr/tap2tcp-down

    # Generate kcptun server config
    cat > /etc/kcptun/server.json << EOF
{
    "listen": "$GCS_IP:$KCPTUN_PORT",
    "target": "127.0.0.1:$TAP2TCP_PORT",
    "key": "$KCPTUN_KEY",
    "crypt": "none",
    "nocomp": true,
    "mode": "manual",
    "acknodelay": true,
    "nodelay": $KCP_NODELAY,
    "interval": $KCP_INTERVAL,
    "resend": $KCP_RESEND,
    "nc": $KCP_NC,
    "datashard": 0,
    "parityshard": 0,
    "mtu": $KCP_SEGMENT_MTU,
    "sndwnd": 1024,
    "rcvwnd": 1024,
    "dscp": 46,
    "sockbuf": $KCP_SOCKBUF,
    "smuxbuf": $KCP_SMUXBUF,
    "smuxver": $KCP_SMUXVER,
    "streambuf": $KCP_STREAM_BUF,
    "snmplog": "/tmp/kcptun-snmp.log",
    "snmpperiod": 5
}
EOF

    # Generate kcptun-server init script
    cat > /etc/init.d/kcptun-server << 'INITSCRIPT'
#!/bin/sh /etc/rc.common
START=90
STOP=10
USE_PROCD=1

start_service() {
    local timeout=60 elapsed=0
    while [ $elapsed -lt $timeout ]; do
        tailscale status >/dev/null 2>&1 && break
        sleep 5; elapsed=$((elapsed + 5))
    done
    local ts_ip=$(tailscale ip -4 2>/dev/null | head -1)
    [ -n "$ts_ip" ] && [ -f /etc/kcptun/server.json ] && \
        sed -i "s|\"listen\": \"[^\"]*:|\"listen\": \"$ts_ip:|g" /etc/kcptun/server.json
    procd_open_instance
    procd_set_param command /usr/bin/kcptun-server -c /etc/kcptun/server.json
    procd_set_param respawn 3600 5 5
    procd_set_param stderr 1
    procd_set_param stdout 1
    procd_close_instance
}
INITSCRIPT
    chmod +x /etc/init.d/kcptun-server

    # Generate tap2tcp init script (server mode)
    cat > /etc/init.d/tap2tcp << 'INITSCRIPT'
#!/bin/sh /etc/rc.common
START=91
STOP=9
USE_PROCD=1

start_service() {
    local timeout=30 elapsed=0
    while [ $elapsed -lt $timeout ]; do
        pgrep -f kcptun-server >/dev/null 2>&1 && break
        sleep 2; elapsed=$((elapsed + 2))
    done
    procd_open_instance
    procd_set_param command /usr/bin/tap2tcp -m server -l 127.0.0.1:655 -t rvr_bridge -u /etc/rvr/tap2tcp-up -d /etc/rvr/tap2tcp-down -s /tmp/tap2tcp.stats -L 1000 -H 2000
    procd_set_param respawn 3600 5 5
    procd_set_param stderr 1
    procd_set_param stdout 1
    procd_close_instance
}

stop_service() {
    # Ensure down script runs even if tap2tcp crashes
    [ -x /etc/rvr/tap2tcp-down ] && /etc/rvr/tap2tcp-down 2>/dev/null || true
}
INITSCRIPT
    chmod +x /etc/init.d/tap2tcp

    /etc/init.d/kcptun-server enable 2>/dev/null
    /etc/init.d/tap2tcp enable 2>/dev/null
    # STP is enabled at runtime by tap2tcp-up — do NOT persist via uci commit
    # which triggers netifd to tear down/rebuild br-lan and can brick the router

    echo "[GCS] Setup complete."

    # AIRCRAFT SETUP
    echo "[Aircraft] Installing packages..."
    ensure_opkg_feeds_remote "$AIRCRAFT_IP"
    ensure_packages_remote "$AIRCRAFT_IP"

    echo "[Aircraft] Configuring tap2tcp..."
