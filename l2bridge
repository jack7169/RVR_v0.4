        ip link set l2bridge nomaster 2>/dev/null || true
        ip link del l2bridge 2>/dev/null || true
        iptables -D OUTPUT -o br-lan -p udp --dport 41641 -j DROP 2>/dev/null || true
        iptables -D OUTPUT -o br-lan -p udp --sport 41641 -j DROP 2>/dev/null || true
        iptables -D FORWARD -i l2bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
        iptables -D FORWARD -o l2bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
        iptables -D FORWARD -i l2bridge -p udp --sport 41641 -j DROP 2>/dev/null || true
        iptables -D FORWARD -o l2bridge -p udp --sport 41641 -j DROP 2>/dev/null || true
