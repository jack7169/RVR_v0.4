#############################################
# START/STOP/RESTART
#############################################
cmd_start_internal() {
    local AIRCRAFT_IP="$1"
    echo "[*] Starting GCS services..."
    start_local_services
    [ -n "$AIRCRAFT_IP" ] && { echo "[*] Starting Aircraft services..."; start_aircraft_services "$AIRCRAFT_IP"; }
    echo "[*] Services started."
}

cmd_start() { cmd_start_internal "$(require_aircraft_ip "$1")"; }

cmd_stop_internal() {
    local AIRCRAFT_IP="$1"
    stop_local_services
    [ -n "$AIRCRAFT_IP" ] && stop_aircraft_services "$AIRCRAFT_IP"
}

cmd_stop() { cmd_stop_internal "$(get_aircraft_ip "$1")"; }

cmd_restart() {
    local AIRCRAFT_IP=$(require_aircraft_ip "$1")
    cmd_stop_internal "$AIRCRAFT_IP"
    sleep $SERVICE_RESTART_DELAY
    cmd_start_internal "$AIRCRAFT_IP"
    echo "[*] Waiting for STP (45s)..."
    sleep 45
    cmd_status
}

#############################################
# STATUS
#############################################
cmd_status() {
    local GCS_IP=$(get_tailscale_ip_nowait)

    echo "========================================="
    echo "  L2 Bridge Status (v4.0)"
    echo "========================================="
    echo ""
    echo "[Tailscale] ${GCS_IP:-NOT READY}"
    echo ""
    echo "[Processes]"
    pgrep -f kcptun-server >/dev/null && echo "  kcptun-server: RUNNING" || echo "  kcptun-server: STOPPED"
    pgrep -x l2tap >/dev/null && echo "  l2tap:         RUNNING" || echo "  l2tap:         STOPPED"
    echo ""
    echo "[Interface]"
    if ip link show l2bridge >/dev/null 2>&1; then
        echo "  l2bridge: UP (MTU: $(ip link show l2bridge | grep -o 'mtu [0-9]*' | cut -d' ' -f2))"
    else
        echo "  l2bridge: NOT FOUND"
    fi
    echo ""
    echo "[L2TAP Streams]"
    if [ -f "$STATS_FILE" ]; then
        . "$STATS_FILE"
        echo "  Active: ${STREAMS:-0}/${MAX_STREAMS:-32} streams, ${FLOWS:-0} flows"
        echo "  Broadcast stream: ${BCAST_STREAM:-down}"
        echo "  TAP RX: ${TAP_RX_FRAMES:-0} frames (${TAP_RX_BYTES:-0} bytes)"
        echo "  TAP TX: ${TAP_TX_FRAMES:-0} frames (${TAP_TX_BYTES:-0} bytes)"
    else
        echo "  No stats available"
    fi
    echo ""
    echo "[Watchdog]"
    crontab -l 2>/dev/null | grep -q "l2bridge-watchdog" && echo "  Status: ACTIVE" || echo "  Status: INACTIVE"
    [ -f "$HEALTH_FILE" ] && { . "$HEALTH_FILE"; echo "  Last: $STATUS ($LAST_CHECK)"; }
    echo ""
    [ -f "$STATE_FILE" ] && { . "$STATE_FILE"; [ -n "$AIRCRAFT_IP" ] && echo "[Aircraft] $AIRCRAFT_IP"; }
}

cmd_remote() {
    local AIRCRAFT_IP=$(require_aircraft_ip "$1")
    check_aircraft_reachable "$AIRCRAFT_IP" || { echo "Aircraft unreachable"; exit 1; }
    ssh_aircraft "$AIRCRAFT_IP" '
        echo "=== Aircraft Status ==="
        pgrep -f kcptun-client >/dev/null && echo "kcptun-client: RUNNING" || echo "kcptun-client: STOPPED"
        pgrep -x l2tap >/dev/null && echo "l2tap: RUNNING" || echo "l2tap: STOPPED"
        ip link show l2bridge 2>/dev/null && echo "l2bridge: UP" || echo "l2bridge: DOWN"
        if [ -f /tmp/l2tap.stats ]; then
            . /tmp/l2tap.stats
            echo "Streams: ${STREAMS:-0}/${MAX_STREAMS:-32}, Flows: ${FLOWS:-0}"
        fi
    '
}

cmd_logs() { logread 2>/dev/null | grep -iE "l2tap|kcptun|l2bridge" | tail -"${1:-20}"; }

cmd_debug() {
    local AIRCRAFT_IP=$(require_aircraft_ip "$1")
    cmd_status
    echo "=== Logs ===" && cmd_logs 10
    echo "=== Watchdog Log ===" && tail -10 /tmp/l2bridge-watchdog.log 2>/dev/null || echo "None"
    check_aircraft_reachable "$AIRCRAFT_IP" && { echo "=== Aircraft ===" && cmd_remote "$AIRCRAFT_IP"; }
}

cmd_config() {
    echo "GCS IP:      $(get_tailscale_ip_nowait)"
    echo "KCP Port:    $KCPTUN_PORT"
    echo "L2TAP Port:  $L2TAP_PORT"
    echo "Bridge MTU:  $BRIDGE_MTU"
    echo "KCP MTU:     $KCP_SEGMENT_MTU"
    [ -f "$STATE_FILE" ] && { . "$STATE_FILE"; echo "Aircraft:    $AIRCRAFT_IP"; }
}

cmd_remove_aircraft() {
    local input="$1"
    [ -z "$input" ] && { echo "Usage: l2bridge remove-aircraft <name|ip>"; exit 1; }
    local AIRCRAFT_IP=$(get_aircraft_ip "$input")
    [ -z "$AIRCRAFT_IP" ] && { echo "ERROR: Could not resolve '$input' to an aircraft IP"; exit 1; }

    echo ""
    echo "This will remove the L2 bridge from aircraft $AIRCRAFT_IP"
    echo "and delete its profile. GCS will remain intact."
    echo ""
    printf "Continue? [y/N] "
    read confirm
    [ "$confirm" != "y" ] && [ "$confirm" != "Y" ] && { echo "Aborted."; exit 0; }

    echo ""

    echo "[*] Stopping bridge services..."
    stop_local_services
    stop_aircraft_services "$AIRCRAFT_IP" 2>/dev/null || true

    if check_aircraft_reachable "$AIRCRAFT_IP" 2>/dev/null; then
        echo "[*] Uninstalling from aircraft ($AIRCRAFT_IP)..."
        ssh_aircraft "$AIRCRAFT_IP" '
            /etc/init.d/kcptun-client stop 2>/dev/null || true
            /etc/init.d/l2tap stop 2>/dev/null || true
            [ -x /etc/l2bridge/l2tap-down ] && /etc/l2bridge/l2tap-down 2>/dev/null || true
            /etc/init.d/kcptun-client disable 2>/dev/null || true
            /etc/init.d/l2tap disable 2>/dev/null || true
            rm -f /etc/init.d/kcptun-client /etc/init.d/l2tap
            rm -rf /etc/l2bridge
            rm -f /etc/kcptun/client.json
            rmdir /etc/kcptun 2>/dev/null || true
            rm -f /usr/bin/l2tap
            uci delete network.@device[0].stp 2>/dev/null || true
            uci commit network 2>/dev/null || true
            opkg remove --force-depends kcptun-client kcptun-config kmod-tun 2>/dev/null || true
            rm -f /tmp/l2bridge* /tmp/l2tap*
        ' 2>/dev/null || log_warn "Aircraft cleanup failed (may need manual cleanup)"
    else
        echo "[!] Aircraft $AIRCRAFT_IP unreachable - skipping remote cleanup"
    fi

    # Remove profile from aircraft.json
    local aircraft_file="/etc/l2bridge/aircraft.json"
    if [ -f "$aircraft_file" ]; then
        local profile_id=$(awk -v ip="$AIRCRAFT_IP" '
            /"[a-zA-Z0-9_-]+"[[:space:]]*:[[:space:]]*\{/ {
                id=$0; sub(/^[^"]*"/, "", id); sub(/".*/, "", id)
                if (id != "profiles") current_id=id
            }
            current_id && /"tailscale_ip"/ && index($0, ip) {
                print current_id; exit
            }
        ' "$aircraft_file")
        if [ -n "$profile_id" ]; then
            echo "[*] Removing profile '$profile_id' from aircraft.json..."
            local active=$(sed -n 's/.*"active"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$aircraft_file" | head -1)
            [ "$active" = "$profile_id" ] && sed -i "s/\"active\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/\"active\": \"\"/" "$aircraft_file"
        fi
    fi

    if [ -f "$STATE_FILE" ]; then
        . "$STATE_FILE"
        [ "${AIRCRAFT_IP:-}" = "$AIRCRAFT_IP" ] && rm -f "$STATE_FILE"
    fi

    echo ""
    echo "Aircraft $AIRCRAFT_IP removed. GCS is still operational."
    echo "Use 'l2bridge add <ip>' to connect a different aircraft."
}

cmd_uninstall() {
    local AIRCRAFT_IP=$(get_aircraft_ip "$1")
    local script_dir=$(dirname "$(readlink -f "$0")")

    echo ""
    echo "This will completely remove RVR L2 Bridge and all configuration."
    echo ""
    echo "The following will be removed:"
    echo "  - L2Bridge services, configs, and init scripts"
    echo "  - Watchdog and auto-start entries"
    [ -d "$WEBUI_ROOT" ] && echo "  - Web UI ($WEBUI_ROOT, uhttpd config, firewall rule)"
    echo "  - Installed packages (kcptun, sshpass, git, etc.)"
    echo "  - l2tap binary"
    [ -n "$AIRCRAFT_IP" ] && echo "  - Aircraft configuration on $AIRCRAFT_IP (if reachable)"
    echo "  - Repository ($script_dir)"
    echo "  - /usr/bin/l2bridge symlink"
    echo ""
    printf "Continue? [y/N] "
    read confirm
    [ "$confirm" != "y" ] && [ "$confirm" != "Y" ] && { echo "Aborted."; exit 0; }

    echo ""

    echo "[*] Stopping services..."
    cmd_stop_internal "$AIRCRAFT_IP" 2>/dev/null || true

    echo "[*] Removing watchdog..."
    cmd_watchdog_remove 2>/dev/null || true

    # Remove Web UI if installed
    if [ -d "$WEBUI_ROOT" ] || uci get uhttpd.l2bridge >/dev/null 2>&1; then
        echo "[*] Removing Web UI..."
        /etc/init.d/uhttpd stop 2>/dev/null || true
        if uci get uhttpd.l2bridge >/dev/null 2>&1; then
            uci delete uhttpd.l2bridge
            uci commit uhttpd
        fi
        if uci get firewall.l2bridge_webui >/dev/null 2>&1; then
            uci delete firewall.l2bridge_webui
            uci commit firewall
            /etc/init.d/firewall reload 2>/dev/null || true
        fi
        rm -rf "$WEBUI_ROOT"
        /etc/init.d/uhttpd start 2>/dev/null || true
    fi

    # Run l2tap-down to clean iptables rules
    echo "[*] Cleaning up iptables rules..."
    [ -x /etc/l2bridge/l2tap-down ] && /etc/l2bridge/l2tap-down 2>/dev/null || true

    echo "[*] Removing GCS service configuration..."
    /etc/init.d/kcptun-server disable 2>/dev/null || true
    /etc/init.d/l2tap disable 2>/dev/null || true
    rm -f /etc/init.d/kcptun-server /etc/init.d/l2tap

    rm -rf /etc/l2bridge
    rm -f /etc/kcptun/server.json
    rmdir /etc/kcptun 2>/dev/null || true
    rm -f "$STATE_FILE" "$HEALTH_FILE"
    rm -f "$L2TAP_BINARY"

    echo "[*] Reverting STP on bridge..."
    uci delete network.@device[0].stp 2>/dev/null || true
    uci commit network 2>/dev/null || true

    # Clean up aircraft
    if [ -n "$AIRCRAFT_IP" ] && check_aircraft_reachable "$AIRCRAFT_IP" 2>/dev/null; then
        echo "[*] Cleaning up aircraft ($AIRCRAFT_IP)..."
        ssh_aircraft "$AIRCRAFT_IP" '
            /etc/init.d/kcptun-client stop 2>/dev/null || true
            /etc/init.d/l2tap stop 2>/dev/null || true
            [ -x /etc/l2bridge/l2tap-down ] && /etc/l2bridge/l2tap-down 2>/dev/null || true
            /etc/init.d/kcptun-client disable 2>/dev/null || true
            /etc/init.d/l2tap disable 2>/dev/null || true
            rm -f /etc/init.d/kcptun-client /etc/init.d/l2tap
            rm -rf /etc/l2bridge
            rm -f /etc/kcptun/client.json
            rmdir /etc/kcptun 2>/dev/null || true
            rm -f /usr/bin/l2tap
            uci delete network.@device[0].stp 2>/dev/null || true
            uci commit network 2>/dev/null || true
            opkg remove --force-depends kcptun-client kcptun-config kmod-tun 2>/dev/null || true
            sed -i "/arch aarch64_cortex-a53_neon-vfpv4 /d" /etc/opkg.conf 2>/dev/null || true
            sed -i "/arch aarch64_cortex-a53 /d" /etc/opkg.conf 2>/dev/null || true
            sed -i "/arch all /d" /etc/opkg.conf 2>/dev/null || true
            sed -i "/openwrt_packages/d" /etc/opkg/customfeeds.conf 2>/dev/null || true
            rm -f /tmp/l2bridge* /tmp/l2tap*
        ' 2>/dev/null || log_warn "Aircraft cleanup failed (may need manual cleanup)"
    elif [ -n "$AIRCRAFT_IP" ]; then
        echo "[!] Aircraft $AIRCRAFT_IP unreachable - skipping remote cleanup"
    fi

    echo "[*] Removing installed packages..."
    opkg remove --force-depends kcptun-server kcptun-config kmod-tun sshpass \
        git git-http libcurl4 ca-bundle liblzo2 2>/dev/null || true

    echo "[*] Reverting opkg configuration..."
    sed -i "/arch aarch64_cortex-a53_neon-vfpv4 /d" /etc/opkg.conf 2>/dev/null || true
    sed -i "/arch aarch64_cortex-a53 /d" /etc/opkg.conf 2>/dev/null || true
    sed -i "/arch all /d" /etc/opkg.conf 2>/dev/null || true
    sed -i "/openwrt_packages/d" /etc/opkg/customfeeds.conf 2>/dev/null || true

    echo "[*] Removing l2bridge..."
    rm -f /usr/bin/l2bridge

    rm -f /tmp/l2bridge* /tmp/l2tap* /tmp/rvr-*

    if [ -d "$script_dir" ]; then
        echo "[*] Removing repository ($script_dir)..."
        rm -rf "$script_dir"
    fi

    echo ""
    echo "=========================================="
    echo "  RVR L2 Bridge fully uninstalled."
    echo "=========================================="
}

#############################################
# WEB UI INSTALL/REMOVE
#############################################
WEBUI_ROOT="/www/rvr"
WEBUI_CONFIG_DIR="/etc/l2bridge"
WEBUI_PORT="8081"

cmd_webui_install() {
    log_info "Installing L2Bridge Web UI..."

    mkdir -p "$WEBUI_ROOT/cgi-bin"
    mkdir -p "$WEBUI_CONFIG_DIR"
    mkdir -p /tmp/l2bridge

    local script_dir=$(dirname "$(readlink -f "$0")")
    local src_www="$script_dir/www"

    if [ -d "$src_www" ]; then
        log_info "Installing from local source: $src_www"
        cp "$src_www/index.html" "$WEBUI_ROOT/"
        if [ -d "$src_www/assets" ]; then
            mkdir -p "$WEBUI_ROOT/assets"
            cp -r "$src_www/assets/"* "$WEBUI_ROOT/assets/"
        fi
        cp "$src_www/cgi-bin/"*.cgi "$WEBUI_ROOT/cgi-bin/"
    else
        log_error "Web UI source files not found at $src_www"
        exit 1
    fi

    chmod +x "$WEBUI_ROOT/cgi-bin/"*.cgi

    local git_hash=$(cd "$script_dir" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    echo "$git_hash" > "$WEBUI_CONFIG_DIR/version"

    local git_remote=$(cd "$script_dir" && git config --get remote.origin.url 2>/dev/null || echo "")
    local repo_path=$(echo "$git_remote" | sed 's|.*github.com[:/]||; s|\.git$||')
    if [ -n "$repo_path" ]; then
        echo "$repo_path" > "$WEBUI_CONFIG_DIR/repo"
    fi

    if [ ! -f "$WEBUI_CONFIG_DIR/aircraft.json" ]; then
        printf '{\n  "version": 1,\n  "active": "",\n  "profiles": {}\n}\n' > "$WEBUI_CONFIG_DIR/aircraft.json"
    fi

    log_info "Configuring uhttpd on port $WEBUI_PORT..."

    if uci get uhttpd.l2bridge >/dev/null 2>&1; then
        log_info "Updating existing uhttpd configuration..."
    else
        log_info "Creating new uhttpd configuration..."
        uci set uhttpd.l2bridge=uhttpd
    fi

    uci set uhttpd.l2bridge.listen_http="0.0.0.0:$WEBUI_PORT"
    uci set uhttpd.l2bridge.home="$WEBUI_ROOT"
    uci set uhttpd.l2bridge.cgi_prefix='/cgi-bin'
    uci set uhttpd.l2bridge.script_timeout='300'
    uci set uhttpd.l2bridge.no_symlinks='0'
    uci set uhttpd.l2bridge.no_dirlists='1'
    uci set uhttpd.l2bridge.rfc1918_filter='0'
    uci commit uhttpd

    /etc/init.d/uhttpd restart

    if command -v fw4 >/dev/null 2>&1 || [ -f /etc/config/firewall ]; then
        log_info "Configuring firewall for port $WEBUI_PORT..."
        if ! uci get firewall.l2bridge_webui >/dev/null 2>&1; then
            uci set firewall.l2bridge_webui=rule
            uci set firewall.l2bridge_webui.name='Allow-L2Bridge-WebUI'
            uci set firewall.l2bridge_webui.src='lan'
            uci set firewall.l2bridge_webui.proto='tcp'
            uci set firewall.l2bridge_webui.dest_port="$WEBUI_PORT"
            uci set firewall.l2bridge_webui.target='ACCEPT'
            uci commit firewall
            /etc/init.d/firewall reload 2>/dev/null || true
        fi
    fi

    if ! crontab -l 2>/dev/null | grep -q "l2bridge-watchdog"; then
        cmd_watchdog_install
    fi

    do_health_check "$(get_aircraft_ip)" >/dev/null 2>&1 || true

    echo ""
    echo "========================================="
    echo "  L2Bridge Web UI Installed"
    echo "========================================="
    echo ""
    echo "  Access the control panel at:"
    echo "  http://$(get_tailscale_ip_nowait 2>/dev/null || echo '<router-ip>'):$WEBUI_PORT"
    echo ""
    local lan_ip=$(ip -4 addr show br-lan 2>/dev/null | awk '/inet / {print $2}' | cut -d'/' -f1 | head -1)
    [ -n "$lan_ip" ] && echo "  Or from LAN: http://$lan_ip:$WEBUI_PORT"
    echo ""
}

cmd_webui_remove() {
    log_info "Removing L2Bridge Web UI..."

    /etc/init.d/uhttpd stop 2>/dev/null || true

    if uci get uhttpd.l2bridge >/dev/null 2>&1; then
        uci delete uhttpd.l2bridge
        uci commit uhttpd
    fi

    if uci get firewall.l2bridge_webui >/dev/null 2>&1; then
        uci delete firewall.l2bridge_webui
        uci commit firewall
        /etc/init.d/firewall reload 2>/dev/null || true
    fi

    rm -rf "$WEBUI_ROOT"
    log_info "Aircraft profiles preserved in $WEBUI_CONFIG_DIR"
    /etc/init.d/uhttpd start

    echo "Web UI removed."
}

#############################################
# UPDATE
#############################################
cmd_update() {
    local repo_dir=""
    local script_path=$(readlink -f "$0" 2>/dev/null || echo "$0")
    local script_dir=$(dirname "$script_path")
    if [ -d "$script_dir/.git" ]; then
        repo_dir="$script_dir"
    elif [ -d "/root/RVR_v0.4/.git" ]; then
        repo_dir="/root/RVR_v0.4"
    fi

    if [ -z "$repo_dir" ]; then
        log_error "Cannot find git repository"
        exit 1
    fi

    echo "Updating L2Bridge from GitHub..."
    echo "  Repository: $repo_dir"

    local old_hash=$(cd "$repo_dir" && git rev-parse --short HEAD 2>/dev/null)
    echo "  Current version: $old_hash"

    cd "$repo_dir"
    git fetch origin main 2>&1 || { log_error "Failed to fetch updates"; exit 1; }

    local new_hash=$(git rev-parse --short origin/main 2>/dev/null)
    if [ "$old_hash" = "$new_hash" ]; then
        echo "  Already up to date ($old_hash)"
        return 0
    fi

    git reset --hard origin/main 2>&1 || { log_error "Failed to apply updates"; exit 1; }
    chmod +x "$repo_dir/l2bridge"
    chmod +x "$repo_dir/www/cgi-bin/"*.cgi 2>/dev/null

    # Update l2tap binary if new one available
    if [ -f "$repo_dir/packages/common/l2tap-aarch64" ]; then
        cp "$repo_dir/packages/common/l2tap-aarch64" "$L2TAP_BINARY"
        chmod +x "$L2TAP_BINARY"
        log_info "Updated l2tap binary"
    fi

    if [ ! -L /usr/bin/l2bridge ] || [ "$(readlink -f /usr/bin/l2bridge)" != "$repo_dir/l2bridge" ]; then
        ln -sf "$repo_dir/l2bridge" /usr/bin/l2bridge
    fi

    echo "  Updated: $old_hash -> $new_hash"

    if [ -d "$WEBUI_ROOT" ]; then
        log_info "Updating web UI files..."
        local src_www="$repo_dir/www"
        if [ -d "$src_www" ]; then
            cp "$src_www/index.html" "$WEBUI_ROOT/"
            if [ -d "$src_www/assets" ]; then
                mkdir -p "$WEBUI_ROOT/assets"
                cp -r "$src_www/assets/"* "$WEBUI_ROOT/assets/"
            fi
            cp "$src_www/cgi-bin/"*.cgi "$WEBUI_ROOT/cgi-bin/"
            chmod +x "$WEBUI_ROOT/cgi-bin/"*.cgi
            echo "$new_hash" > "$WEBUI_CONFIG_DIR/version"
            rm -f /tmp/l2bridge-latest-version
            log_info "Web UI updated"
        fi
    fi

    local AIRCRAFT_IP=$(get_aircraft_ip 2>/dev/null)
    if [ -n "$AIRCRAFT_IP" ] && pgrep -x l2tap >/dev/null 2>&1; then
        log_info "Restarting bridge to apply updates..."
        cmd_restart "$AIRCRAFT_IP"
    fi

    echo ""
    echo "Update complete."
}

#############################################
# ADD (CONNECT TO EXISTING AIRCRAFT)
#############################################
cmd_add() {
    local AIRCRAFT_IP="$1"
    local AIRCRAFT_NAME="$2"

    [ -z "$AIRCRAFT_IP" ] && { echo "ERROR: Usage: l2bridge add <aircraft_ip> [aircraft_name]"; exit 1; }

    local GCS_IP=$(get_local_tailscale_ip)

    local aircraft_password=""
    local existing_name=""
    if [ -f "/etc/l2bridge/aircraft.json" ]; then
        aircraft_password=$(awk -v ip="$AIRCRAFT_IP" '
            BEGIN { in_profile=0; current_ip=""; current_pass="" }
            /"[a-zA-Z0-9_-]+":[[:space:]]*\{/ { in_profile=1; current_ip=""; current_pass="" }
            in_profile && /"tailscale_ip":/ {
                gsub(/.*"tailscale_ip":[[:space:]]*"/, ""); gsub(/".*/, "")
                current_ip = $0
            }
            in_profile && /"ssh_password":/ {
                gsub(/.*"ssh_password":[[:space:]]*"/, ""); gsub(/".*/, "")
                current_pass = $0
            }
            /\}/ {
                if (in_profile && current_ip == ip && current_pass != "") {
                    print current_pass
                    exit
                }
                in_profile = 0
            }
        ' /etc/l2bridge/aircraft.json 2>/dev/null)

        existing_name=$(awk -v ip="$AIRCRAFT_IP" '
            BEGIN { in_profile=0; current_ip=""; current_name="" }
            /"[a-zA-Z0-9_-]+":[[:space:]]*\{/ { in_profile=1; current_ip=""; current_name="" }
            in_profile && /"tailscale_ip":/ {
                gsub(/.*"tailscale_ip":[[:space:]]*"/, ""); gsub(/".*/, "")
                current_ip = $0
            }
            in_profile && /"name":/ {
                gsub(/.*"name":[[:space:]]*"/, ""); gsub(/".*/, "")
                current_name = $0
            }
            /\}/ {
                if (in_profile && current_ip == ip && current_name != "") {
                    print current_name
                    exit
                }
                in_profile = 0
            }
        ' /etc/l2bridge/aircraft.json 2>/dev/null)
    fi

    if [ -z "$AIRCRAFT_NAME" ]; then
        if [ -n "$existing_name" ]; then
            AIRCRAFT_NAME="$existing_name"
        else
            echo "ERROR: Aircraft name required for new aircraft. Usage: l2bridge add <aircraft_ip> <aircraft_name>"
            exit 1
        fi
    fi

    echo "========================================="
    echo "  L2 Bridge - Connect to Aircraft"
    echo "========================================="
    echo "  GCS:      $GCS_IP"
    echo "  Aircraft: $AIRCRAFT_IP ($AIRCRAFT_NAME)"
    echo "========================================="
    echo ""

    echo "[*] Testing connectivity..."
    check_aircraft_reachable "$AIRCRAFT_IP" || { echo "ERROR: Cannot reach aircraft at $AIRCRAFT_IP"; exit 1; }
    echo "    Aircraft reachable."

    setup_ssh_keys "$AIRCRAFT_IP" "$aircraft_password" || exit 1

    # Verify l2bridge is installed on both sides
    echo "[*] Verifying l2bridge installation..."
    [ -x "$L2TAP_BINARY" ] || { echo "ERROR: l2tap not installed on GCS. Run 'l2bridge setup $AIRCRAFT_IP' first."; exit 1; }
    ssh_aircraft "$AIRCRAFT_IP" "[ -x /usr/bin/l2tap ]" 2>/dev/null || {
        echo "ERROR: l2tap not installed on aircraft. Run 'l2bridge setup $AIRCRAFT_IP' first."
        exit 1
    }
    echo "    Both sides have l2tap installed."

    echo "[*] Stopping existing services..."
    cmd_stop_internal "$(get_aircraft_ip)" 2>/dev/null || true

    # Update kcptun configs with current GCS IP
    echo "[*] Updating kcptun configuration..."
    if [ -f /etc/kcptun/server.json ]; then
        sed -i "s|\"listen\": \"[^\"]*:|\"listen\": \"$GCS_IP:|g" /etc/kcptun/server.json
    fi
    ssh_aircraft "$AIRCRAFT_IP" "
        [ -f /etc/kcptun/client.json ] && sed -i 's|\"remoteaddr\": \"[^\"]*:|\"remoteaddr\": \"$GCS_IP:|g' /etc/kcptun/client.json
    " 2>/dev/null
    echo "    Configuration updated."

    save_aircraft_ip "$AIRCRAFT_IP"
    save_aircraft_profile "$AIRCRAFT_NAME" "$AIRCRAFT_IP"

    echo "[*] Starting services..."
    cmd_start_internal "$AIRCRAFT_IP"

    echo "[*] Waiting for STP convergence (45s)..."
    sleep 45

    echo ""
    cmd_status
    echo ""
    echo "Aircraft '$AIRCRAFT_NAME' ($AIRCRAFT_IP) connected."
}

#############################################
# CAPTURE COMMAND
#############################################
CAPTURE_PID_FILE="/tmp/l2bridge-capture.pid"
CAPTURE_DEFAULT_FILE="/tmp/l2bridge-capture.pcap"
CAPTURE_DEFAULT_DURATION=60

cmd_capture() {
    local subcmd="${1:-start}"
    shift 2>/dev/null || true

    case "$subcmd" in
        stop)
            if [ -f "$CAPTURE_PID_FILE" ]; then
                local pid=$(cat "$CAPTURE_PID_FILE")
                if kill -0 "$pid" 2>/dev/null; then
                    kill "$pid" 2>/dev/null
                    sleep 1
                    kill -9 "$pid" 2>/dev/null || true
                    echo "Capture stopped (PID $pid)"
                else
                    echo "Capture process not running"
                fi
                rm -f "$CAPTURE_PID_FILE" "/tmp/l2bridge-capture.start"
            else
                echo "No active capture"
            fi
            local capfile="$CAPTURE_DEFAULT_FILE"
            if [ -f "$capfile" ]; then
                local size=$(wc -c < "$capfile")
                echo "Capture file: $capfile ($size bytes)"
            fi
            ;;
        status)
            if [ -f "$CAPTURE_PID_FILE" ] && kill -0 "$(cat "$CAPTURE_PID_FILE")" 2>/dev/null; then
                local pid=$(cat "$CAPTURE_PID_FILE")
                echo "Capture running (PID $pid)"
            else
                rm -f "$CAPTURE_PID_FILE"
                echo "No active capture"
            fi
            local capfile="$CAPTURE_DEFAULT_FILE"
            if [ -f "$capfile" ]; then
                local size=$(wc -c < "$capfile")
                echo "Capture file: $capfile ($size bytes)"
            else
                echo "No capture file"
            fi
            ;;
        start|[0-9]*)
            local duration="$CAPTURE_DEFAULT_DURATION"
            local outfile="$CAPTURE_DEFAULT_FILE"
            if echo "$subcmd" | grep -qE '^[0-9]+$'; then
                duration="$subcmd"
            elif [ -n "$1" ] && echo "$1" | grep -qE '^[0-9]+$'; then
                duration="$1"; shift 2>/dev/null || true
            fi
            [ -n "$1" ] && outfile="$1"

            if [ -f "$CAPTURE_PID_FILE" ] && kill -0 "$(cat "$CAPTURE_PID_FILE")" 2>/dev/null; then
                echo "Capture already running (PID $(cat "$CAPTURE_PID_FILE")). Stop it first."
                return 1
            fi

            if ! command -v tcpdump >/dev/null 2>&1; then
                echo "Error: tcpdump not installed. Run: opkg install tcpdump"
                return 1
            fi

            if ! ip link show l2bridge >/dev/null 2>&1; then
                echo "Error: l2bridge interface not found. Is the bridge running?"
                return 1
            fi

            echo "Starting capture on l2bridge for ${duration}s -> $outfile"
            (tcpdump -i l2bridge -s 0 -w "$outfile" >/dev/null 2>&1 & echo $! > "$CAPTURE_PID_FILE"; wait $!; rm -f "$CAPTURE_PID_FILE" "/tmp/l2bridge-capture.start") >/dev/null 2>&1 &
            sleep 1
            local pid=$(cat "$CAPTURE_PID_FILE" 2>/dev/null)
            date +%s > /tmp/l2bridge-capture.start
            (sleep "$duration"; [ -f "$CAPTURE_PID_FILE" ] && kill "$(cat "$CAPTURE_PID_FILE")" 2>/dev/null) >/dev/null 2>&1 &
            echo "Capture started (PID ${pid:-?}, duration ${duration}s)"
            echo "Stop early with: l2bridge capture stop"
            echo "Download file: $outfile"
            ;;
        *)
            echo "Usage: l2bridge capture [start|stop|status] [duration] [file]"
            ;;
    esac
}

#############################################
# MAIN
#############################################
CMD="$1"; shift 2>/dev/null || true

case "$CMD" in
    setup) cmd_setup "$@" ;;
    add|connect) cmd_add "$@" ;;
    start) cmd_start "$@" ;;
    stop) cmd_stop "$@" ;;
    restart) cmd_restart "$@" ;;
    status|st) cmd_status ;;
    remote|rem) cmd_remote "$@" ;;
    logs|log) cmd_logs "$@" ;;
    debug|dbg) cmd_debug "$@" ;;
    config|cfg) cmd_config ;;
    monitor|mon) cmd_monitor "$@" ;;
    watchdog-install) cmd_watchdog_install ;;
    watchdog-remove) cmd_watchdog_remove ;;
    webui-install) cmd_webui_install ;;
    webui-remove) cmd_webui_remove ;;
    capture|cap) cmd_capture "$@" ;;
    update) cmd_update ;;
    remove-aircraft) cmd_remove_aircraft "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    help|-h|--help) print_usage ;;
    "") print_usage; exit 1 ;;
    *) echo "Unknown: $CMD"; print_usage; exit 1 ;;
esac
