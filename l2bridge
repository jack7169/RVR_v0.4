stop_aircraft_services() {
    local AIRCRAFT_IP="$1"
    log_info "Stopping aircraft services..."
    check_aircraft_reachable "$AIRCRAFT_IP" && ssh_aircraft "$AIRCRAFT_IP" '
        /etc/init.d/l2tap stop 2>/dev/null || true
        /etc/init.d/kcptun-client stop 2>/dev/null || true
