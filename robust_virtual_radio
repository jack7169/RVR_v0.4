    log_cmd "Aircraft rvr interface" ssh_aircraft "$AIRCRAFT_IP" "ip link show rvr_bridge 2>/dev/null || echo 'rvr_bridge NOT FOUND'"
    log_cmd "Aircraft bridge membership" ssh_aircraft "$AIRCRAFT_IP" "bridge link show 2>/dev/null"
