        echo "  Active streams: ${STREAMS:-0}/${MAX_STREAMS:-32}"
        echo "  Active flows:   ${FLOWS:-0}"
        echo "  Broadcast:      ${BCAST_STREAM:-down}"
    else
        echo "  Stats not yet available (tap2tcp may still be initializing)"
    fi

    echo ""
    echo "Setup log saved to: $SETUP_LOG"
    echo ""

    cmd_status
    [ $bridge_ok -ne 0 ] && return 1
    return 0
}

#############################################
# START/STOP/RESTART
#############################################
cmd_start_internal() {
    local AIRCRAFT_IP="$1"
    echo "[*] Starting GCS services..."
    start_local_services
    [ -n "$AIRCRAFT_IP" ] && { echo "[*] Starting Aircraft services..."; start_aircraft_services "$AIRCRAFT_IP"; }
    echo "[*] Services started."
}

cmd_start() { cmd_start_internal "$(require_aircraft_ip "$1")"; }

cmd_stop_internal() {
    local AIRCRAFT_IP="$1"
    stop_local_services
    [ -n "$AIRCRAFT_IP" ] && stop_aircraft_services "$AIRCRAFT_IP"
}

cmd_stop() { cmd_stop_internal "$(get_aircraft_ip "$1")"; }

cmd_restart() {
    local AIRCRAFT_IP=$(require_aircraft_ip "$1")
    cmd_stop_internal "$AIRCRAFT_IP"
    sleep $SERVICE_RESTART_DELAY
    cmd_start_internal "$AIRCRAFT_IP"
    wait_for_bridge
    cmd_status
}

#############################################
# STATUS
#############################################
cmd_status() {
    local GCS_IP=$(get_tailscale_ip_nowait)

    echo "========================================="
    echo "  RVR Status (v0.4)"
    echo "========================================="
    echo ""
    echo "[Tailscale] ${GCS_IP:-NOT READY}"
    echo ""
    echo "[Processes]"
    pgrep -f kcptun-server >/dev/null && echo "  kcptun-server: RUNNING" || echo "  kcptun-server: STOPPED"
    pgrep tap2tcp >/dev/null && echo "  tap2tcp:      RUNNING" || echo "  tap2tcp:      STOPPED"
    echo ""
    echo "[Interface]"
    if ip link show rvr_bridge >/dev/null 2>&1; then
        echo "  rvr_bridge: UP (MTU: $(ip link show rvr_bridge | grep -o 'mtu [0-9]*' | cut -d' ' -f2))"
    else
        echo "  rvr_bridge: NOT FOUND"
    fi
    echo ""
    echo "[Tap2TCP Streams]"
    if [ -f "$STATS_FILE" ]; then
        . "$STATS_FILE"
        echo "  Active: ${STREAMS:-0}/${MAX_STREAMS:-32} streams, ${FLOWS:-0} flows"
        echo "  Broadcast stream: ${BCAST_STREAM:-down}"
        echo "  TAP RX: ${TAP_RX_FRAMES:-0} frames (${TAP_RX_BYTES:-0} bytes)"
        echo "  TAP TX: ${TAP_TX_FRAMES:-0} frames (${TAP_TX_BYTES:-0} bytes)"
    else
        echo "  No stats available"
    fi
    echo ""
    echo "[Watchdog]"
    crontab -l 2>/dev/null | grep -q "rvr-watchdog" && echo "  Status: ACTIVE" || echo "  Status: INACTIVE"
    [ -f "$HEALTH_FILE" ] && { . "$HEALTH_FILE"; echo "  Last: $STATUS ($LAST_CHECK)"; }
    echo ""
    [ -f "$STATE_FILE" ] && { . "$STATE_FILE"; [ -n "$AIRCRAFT_IP" ] && echo "[Aircraft] $AIRCRAFT_IP"; }
}

cmd_remote() {
    local AIRCRAFT_IP=$(require_aircraft_ip "$1")
    check_aircraft_reachable "$AIRCRAFT_IP" || { echo "Aircraft unreachable"; exit 1; }
    ssh_aircraft "$AIRCRAFT_IP" '
        echo "=== Aircraft Status ==="
        pgrep -f kcptun-client >/dev/null && echo "kcptun-client: RUNNING" || echo "kcptun-client: STOPPED"
        pgrep tap2tcp >/dev/null && echo "tap2tcp: RUNNING" || echo "tap2tcp: STOPPED"
        ip link show rvr_bridge 2>/dev/null && echo "rvr_bridge: UP" || echo "rvr_bridge: DOWN"
        if [ -f /tmp/tap2tcp.stats ]; then
            . /tmp/tap2tcp.stats
            echo "Streams: ${STREAMS:-0}/${MAX_STREAMS:-32}, Flows: ${FLOWS:-0}"
        fi
    '
}

cmd_logs() { logread 2>/dev/null | grep -iE "tap2tcp|kcptun|rvr" | tail -"${1:-20}"; }

cmd_debug() {
    local AIRCRAFT_IP=$(require_aircraft_ip "$1")
    cmd_status
    echo "=== Logs ===" && cmd_logs 10
    echo "=== Watchdog Log ===" && tail -10 /tmp/rvr-watchdog.log 2>/dev/null || echo "None"
