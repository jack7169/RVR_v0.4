cmd_branches() {
    local repo_dir=""
    local script_path=$(readlink -f "$0" 2>/dev/null || echo "$0")
    local script_dir=$(dirname "$script_path")
    if [ -d "$script_dir/.git" ]; then
        repo_dir="$script_dir"
    elif [ -d "/root/RVR_v0.4/.git" ]; then
        repo_dir="/root/RVR_v0.4"
    fi

    if [ -z "$repo_dir" ]; then
        log_error "Cannot find git repository"
        exit 1
    fi

    local current=$(cat "$WEBUI_CONFIG_DIR/branch" 2>/dev/null || echo "main")
    echo "Current branch: $current"
    echo ""
    echo "Available branches:"
    cd "$repo_dir"
    git ls-remote --heads origin 2>/dev/null | awk '{
        branch = substr($2, 12)
        print "  " branch
    }'
}

#############################################
# ADD (CONNECT TO EXISTING AIRCRAFT)
#############################################
cmd_add() {
    local AIRCRAFT_IP="$1"
    local AIRCRAFT_NAME="$2"

    [ -z "$AIRCRAFT_IP" ] && { echo "ERROR: Usage: rvr add <aircraft_ip> [aircraft_name]"; exit 1; }

    local GCS_IP=$(get_local_tailscale_ip)

    local aircraft_password=""
    local existing_name=""
    if [ -f "/etc/rvr/aircraft.json" ]; then
        aircraft_password=$(awk -v ip="$AIRCRAFT_IP" '
            BEGIN { in_profile=0; current_ip=""; current_pass="" }
            /"[a-zA-Z0-9_-]+":[[:space:]]*\{/ { in_profile=1; current_ip=""; current_pass="" }
            in_profile && /"tailscale_ip":/ {
                gsub(/.*"tailscale_ip":[[:space:]]*"/, ""); gsub(/".*/, "")
                current_ip = $0
            }
            in_profile && /"ssh_password":/ {
                gsub(/.*"ssh_password":[[:space:]]*"/, ""); gsub(/".*/, "")
                current_pass = $0
            }
            /\}/ {
                if (in_profile && current_ip == ip && current_pass != "") {
                    print current_pass
                    exit
                }
                in_profile = 0
            }
        ' /etc/rvr/aircraft.json 2>/dev/null)

        existing_name=$(awk -v ip="$AIRCRAFT_IP" '
            BEGIN { in_profile=0; current_ip=""; current_name="" }
            /"[a-zA-Z0-9_-]+":[[:space:]]*\{/ { in_profile=1; current_ip=""; current_name="" }
            in_profile && /"tailscale_ip":/ {
                gsub(/.*"tailscale_ip":[[:space:]]*"/, ""); gsub(/".*/, "")
                current_ip = $0
            }
            in_profile && /"name":/ {
                gsub(/.*"name":[[:space:]]*"/, ""); gsub(/".*/, "")
                current_name = $0
            }
            /\}/ {
                if (in_profile && current_ip == ip && current_name != "") {
                    print current_name
                    exit
                }
                in_profile = 0
            }
        ' /etc/rvr/aircraft.json 2>/dev/null)
    fi

    if [ -z "$AIRCRAFT_NAME" ]; then
        if [ -n "$existing_name" ]; then
            AIRCRAFT_NAME="$existing_name"
        else
            echo "ERROR: Aircraft name required for new aircraft. Usage: rvr add <aircraft_ip> <aircraft_name>"
            exit 1
        fi
    fi

    echo "========================================="
    echo "  RVR - Connect to Aircraft"
    echo "========================================="
    echo "  GCS:      $GCS_IP"
    echo "  Aircraft: $AIRCRAFT_IP ($AIRCRAFT_NAME)"
    echo "========================================="
    echo ""

    echo "[*] Testing connectivity..."
    check_aircraft_reachable "$AIRCRAFT_IP" || { echo "ERROR: Cannot reach aircraft at $AIRCRAFT_IP"; exit 1; }
    echo "    Aircraft reachable."

    setup_ssh_keys "$AIRCRAFT_IP" "$aircraft_password" || exit 1

    # Verify rvr is installed on both sides
    echo "[*] Verifying rvr installation..."
    [ -x "$TAP2TCP_BINARY" ] || { echo "ERROR: tap2tcp not installed on GCS. Run 'rvr setup $AIRCRAFT_IP' first."; exit 1; }
    ssh_aircraft "$AIRCRAFT_IP" "[ -x /usr/bin/tap2tcp ]" 2>/dev/null || {
        echo "ERROR: tap2tcp not installed on aircraft. Run 'rvr setup $AIRCRAFT_IP' first."
        exit 1
    }
    echo "    Both sides have tap2tcp installed."

    echo "[*] Stopping existing services..."
    cmd_stop_internal "$(get_aircraft_ip)" 2>/dev/null || true

    # Update kcptun configs with current GCS IP
    echo "[*] Updating kcptun configuration..."
    if [ -f /etc/kcptun/server.json ]; then
        sed -i "s|\"listen\": \"[^\"]*:|\"listen\": \"$GCS_IP:|g" /etc/kcptun/server.json
    fi
    ssh_aircraft "$AIRCRAFT_IP" "
        [ -f /etc/kcptun/client.json ] && sed -i 's|\"remoteaddr\": \"[^\"]*:|\"remoteaddr\": \"$GCS_IP:|g' /etc/kcptun/client.json
    " 2>/dev/null
    echo "    Configuration updated."

    save_aircraft_ip "$AIRCRAFT_IP"
    save_aircraft_profile "$AIRCRAFT_NAME" "$AIRCRAFT_IP"

    # Sync binding profile to aircraft
    local GCS_HOSTNAME=$(cat /proc/sys/kernel/hostname 2>/dev/null || echo "GCS")
    ssh_aircraft "$AIRCRAFT_IP" "
        mkdir -p /etc/rvr
        printf '{\"version\":1,\"active\":\"gcs\",\"profiles\":{\"gcs\":{\"name\":\"$GCS_HOSTNAME\",\"tailscale_ip\":\"$GCS_IP\",\"ssh_password\":\"\",\"created\":\"$(date -Iseconds 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S')\",\"last_used\":\"$(date -Iseconds 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S')\"}}}' > /etc/rvr/aircraft.json
        echo 'AIRCRAFT_IP=\"$GCS_IP\"' > /etc/rvr.conf
    " 2>/dev/null || true

    echo "[*] Starting services..."
    cmd_start_internal "$AIRCRAFT_IP"

    wait_for_bridge

    echo ""
    cmd_status
    echo ""
    echo "Aircraft '$AIRCRAFT_NAME' ($AIRCRAFT_IP) connected."
}

#############################################
# CAPTURE COMMAND
#############################################
CAPTURE_PID_FILE="/tmp/rvr-capture.pid"
CAPTURE_DEFAULT_FILE="/tmp/rvr-capture.pcap"
CAPTURE_DEFAULT_DURATION=60

cmd_capture() {
    local subcmd="${1:-start}"
    shift 2>/dev/null || true

    case "$subcmd" in
        stop)
            if [ -f "$CAPTURE_PID_FILE" ]; then
                local pid=$(cat "$CAPTURE_PID_FILE")
                if kill -0 "$pid" 2>/dev/null; then
                    kill "$pid" 2>/dev/null
                    sleep 1
                    kill -9 "$pid" 2>/dev/null || true
                    echo "Capture stopped (PID $pid)"
                else
                    echo "Capture process not running"
                fi
                rm -f "$CAPTURE_PID_FILE" "/tmp/rvr-capture.start"
            else
                echo "No active capture"
            fi
            local capfile="$CAPTURE_DEFAULT_FILE"
            if [ -f "$capfile" ]; then
                local size=$(wc -c < "$capfile")
                echo "Capture file: $capfile ($size bytes)"
            fi
            ;;
        status)
            if [ -f "$CAPTURE_PID_FILE" ] && kill -0 "$(cat "$CAPTURE_PID_FILE")" 2>/dev/null; then
                local pid=$(cat "$CAPTURE_PID_FILE")
                echo "Capture running (PID $pid)"
            else
                rm -f "$CAPTURE_PID_FILE"
                echo "No active capture"
            fi
            local capfile="$CAPTURE_DEFAULT_FILE"
            if [ -f "$capfile" ]; then
                local size=$(wc -c < "$capfile")
                echo "Capture file: $capfile ($size bytes)"
            else
                echo "No capture file"
            fi
            ;;
        start|[0-9]*)
            local duration="$CAPTURE_DEFAULT_DURATION"
            local outfile="$CAPTURE_DEFAULT_FILE"
            if echo "$subcmd" | grep -qE '^[0-9]+$'; then
                duration="$subcmd"
            elif [ -n "$1" ] && echo "$1" | grep -qE '^[0-9]+$'; then
                duration="$1"; shift 2>/dev/null || true
            fi
            [ -n "$1" ] && outfile="$1"

            if [ -f "$CAPTURE_PID_FILE" ] && kill -0 "$(cat "$CAPTURE_PID_FILE")" 2>/dev/null; then
                echo "Capture already running (PID $(cat "$CAPTURE_PID_FILE")). Stop it first."
                return 1
            fi

            if ! command -v tcpdump >/dev/null 2>&1; then
                echo "Error: tcpdump not installed. Run: opkg install tcpdump"
                return 1
            fi

            if ! ip link show rvr_bridge >/dev/null 2>&1; then
                echo "Error: rvr interface not found. Is the bridge running?"
                return 1
            fi

            echo "Starting capture on rvr for ${duration}s -> $outfile"
            (tcpdump -i rvr_bridge -s 0 -w "$outfile" >/dev/null 2>&1 & echo $! > "$CAPTURE_PID_FILE"; wait $!; rm -f "$CAPTURE_PID_FILE" "/tmp/rvr-capture.start") >/dev/null 2>&1 &
            sleep 1
            local pid=$(cat "$CAPTURE_PID_FILE" 2>/dev/null)
            date +%s > /tmp/rvr-capture.start
            (sleep "$duration"; [ -f "$CAPTURE_PID_FILE" ] && kill "$(cat "$CAPTURE_PID_FILE")" 2>/dev/null) >/dev/null 2>&1 &
            echo "Capture started (PID ${pid:-?}, duration ${duration}s)"
            echo "Stop early with: rvr capture stop"
            echo "Download file: $outfile"
            ;;
        *)
            echo "Usage: rvr capture [start|stop|status] [duration] [file]"
            ;;
    esac
}

#############################################
# MAIN
#############################################
CMD="$1"; shift 2>/dev/null || true

case "$CMD" in
    setup) cmd_setup "$@" ;;
    add|connect) cmd_add "$@" ;;
    start) cmd_start "$@" ;;
    stop) cmd_stop "$@" ;;
    restart) cmd_restart "$@" ;;
    status|st) cmd_status ;;
    remote|rem) cmd_remote "$@" ;;
    logs|log) cmd_logs "$@" ;;
    debug|dbg) cmd_debug "$@" ;;
    config|cfg) cmd_config ;;
    monitor|mon) cmd_monitor "$@" ;;
    watchdog-install) cmd_watchdog_install ;;
    watchdog-remove) cmd_watchdog_remove ;;
    webui-install) cmd_webui_install ;;
    webui-remove) cmd_webui_remove ;;
    capture|cap) cmd_capture "$@" ;;
    update) cmd_update "$@" ;;
    branches) cmd_branches ;;
    profile|prof) cmd_profile "$@" ;;
    unbind) cmd_unbind "$@" ;;
    remove-aircraft) cmd_remove_aircraft "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    help|-h|--help) print_usage ;;
    "") print_usage; exit 1 ;;
    *) echo "Unknown: $CMD"; print_usage; exit 1 ;;
esac
