log_msg() {
    local level="$1"
    local msg="$2"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[$timestamp] [$level] $msg"
    logger -t l2bridge -p "daemon.$level" "$msg" 2>/dev/null || true
}

log_info() { log_msg "info" "$1"; }
log_warn() { log_msg "warn" "$1"; }
log_error() { log_msg "err" "$1"; }

get_tailscale_ip_nowait() {
    tailscale ip -4 2>/dev/null | head -1
}

get_local_tailscale_ip() {
    local ip=$(get_tailscale_ip_nowait)
    if [ -z "$ip" ]; then
        echo "ERROR: Could not get Tailscale IP. Is Tailscale running?" >&2
        exit 1
    fi
    echo "$ip"
}

wait_for_tailscale() {
    local timeout="${1:-$TAILSCALE_WAIT_TIMEOUT}"
    local elapsed=0

    log_info "Waiting for Tailscale (timeout: ${timeout}s)..."

    while [ $elapsed -lt $timeout ]; do
        if tailscale status >/dev/null 2>&1; then
            local ip=$(get_tailscale_ip_nowait)
            if [ -n "$ip" ]; then
                log_info "Tailscale ready with IP: $ip"
                return 0
            fi
        fi
        sleep $TAILSCALE_CHECK_INTERVAL
        elapsed=$((elapsed + TAILSCALE_CHECK_INTERVAL))
    done

    log_error "Tailscale not ready after ${timeout}s"
    return 1
}

is_tailscale_ready() {
    tailscale status >/dev/null 2>&1 && [ -n "$(get_tailscale_ip_nowait)" ]
}

resolve_aircraft() {
    local input="$1"
    [ -z "$input" ] && return
    echo "$input" | grep -qE '^100\.' && { echo "$input"; return; }
    local aircraft_file="/etc/l2bridge/aircraft.json"
    [ -f "$aircraft_file" ] || return
    local ip=$(awk -v id="$input" '
        /"'"$input"'"[[:space:]]*:/ { found=1 }
        found && /"tailscale_ip"/ { gsub(/.*"tailscale_ip"[[:space:]]*:[[:space:]]*"/, ""); gsub(/".*/, ""); print; exit }
    ' "$aircraft_file")
    if [ -n "$ip" ]; then echo "$ip"; return; fi
    ip=$(awk -v name="$input" '
        BEGIN { IGNORECASE=1 }
        /"name"[[:space:]]*:/ {
            n=$0; gsub(/.*"name"[[:space:]]*:[[:space:]]*"/, "", n); gsub(/".*/, "", n)
            if (tolower(n) == tolower(name)) found=1
        }
        found && /"tailscale_ip"/ { gsub(/.*"tailscale_ip"[[:space:]]*:[[:space:]]*"/, ""); gsub(/".*/, ""); print; exit }
    ' "$aircraft_file")
    [ -n "$ip" ] && echo "$ip"
}

get_aircraft_ip() {
    if [ -n "$1" ]; then
        local resolved=$(resolve_aircraft "$1")
        if [ -n "$resolved" ]; then
            echo "$resolved"
        else
            echo "$1"
        fi
    elif [ -f "$STATE_FILE" ]; then
        . "$STATE_FILE"
        echo "${AIRCRAFT_IP:-}"
    fi
}

require_aircraft_ip() {
    local ip=$(get_aircraft_ip "$1")
    if [ -z "$ip" ]; then
        echo "ERROR: Aircraft IP required."
        exit 1
    fi
    echo "$ip"
}

save_aircraft_ip() {
    echo "AIRCRAFT_IP=\"$1\"" > "$STATE_FILE"
}

save_aircraft_profile() {
    local name="$1"
    local ip="$2"
    local aircraft_file="/etc/l2bridge/aircraft.json"

    mkdir -p /etc/l2bridge

    local id=$(echo "$name" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9_-]/-/g; s/--*/-/g; s/^-//; s/-$//')
    [ -z "$id" ] && id="aircraft-$(echo "$ip" | tr '.' '-')"

    local created=$(date -Iseconds 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S')

    if [ ! -f "$aircraft_file" ]; then
        printf '{\n  "version": 1,\n  "active": "",\n  "profiles": {}\n}\n' > "$aircraft_file"
    fi

    local tmp_profiles=$(mktemp)
    awk '
    /"[a-zA-Z0-9_-]+":[[:space:]]*\{/ {
        pid = $0
        sub(/^[^"]*"/, "", pid)
        sub(/".*/, "", pid)
        if (pid != "profiles") {
            current_id = pid
            p_pass[current_id] = ""
        }
    }
    current_id && /"name":/ {
        val = $0; sub(/.*"name":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_name[current_id] = val
    }
    current_id && /"tailscale_ip":/ {
        val = $0; sub(/.*"tailscale_ip":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_ip[current_id] = val
    }
    current_id && /"ssh_password":/ {
        val = $0; sub(/.*"ssh_password":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_pass[current_id] = val
    }
    current_id && /"created":/ {
        val = $0; sub(/.*"created":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_created[current_id] = val
    }
    current_id && /"last_used":/ {
        val = $0; sub(/.*"last_used":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_last[current_id] = val
        print current_id "|" p_name[current_id] "|" p_ip[current_id] "|" p_pass[current_id] "|" p_created[current_id] "|" p_last[current_id]
    }
    ' "$aircraft_file" > "$tmp_profiles"

    local found=0
    local tmp_updated=$(mktemp)
    while IFS='|' read -r pid pname pip ppass pcreated plast; do
        [ -z "$pid" ] && continue
        if [ "$pid" = "$id" ] || [ "$pip" = "$ip" ]; then
            echo "$id|$name|$ip|$ppass|$pcreated|$created"
            found=1
        else
            echo "$pid|$pname|$pip|$ppass|$pcreated|$plast"
        fi
    done < "$tmp_profiles" > "$tmp_updated"

    if [ "$found" = "0" ]; then
        echo "$id|$name|$ip||$created|$created" >> "$tmp_updated"
    fi

    printf '{\n  "version": 1,\n  "active": "%s",\n  "profiles": {\n' "$id" > "$aircraft_file"

    local first=1
    while IFS='|' read -r pid pname pip ppass pcreated plast; do
        [ -z "$pid" ] && continue
        [ $first -eq 0 ] && printf ',\n' >> "$aircraft_file"
        printf '    "%s": {\n' "$pid" >> "$aircraft_file"
        printf '      "name": "%s",\n' "$pname" >> "$aircraft_file"
        printf '      "tailscale_ip": "%s",\n' "$pip" >> "$aircraft_file"
        printf '      "ssh_password": "%s",\n' "$ppass" >> "$aircraft_file"
        printf '      "created": "%s",\n' "$pcreated" >> "$aircraft_file"
        printf '      "last_used": "%s"\n' "$plast" >> "$aircraft_file"
        printf '    }' >> "$aircraft_file"
        first=0
    done < "$tmp_updated"

    printf '\n  }\n}\n' >> "$aircraft_file"
    rm -f "$tmp_profiles" "$tmp_updated"

    echo "[*] Aircraft profile '$name' ($id) saved and set active."
}

check_aircraft_reachable() {
    ping -c 1 -W 5 "$1" > /dev/null 2>&1
}

ensure_ssh_key() {
    if [ ! -f "$SSH_KEY" ]; then
        echo "[*] Generating SSH key..."
        mkdir -p /root/.ssh
        chmod 700 /root/.ssh
        dropbearkey -t ed25519 -f "$SSH_KEY" >/dev/null 2>&1
        dropbearkey -y -f "$SSH_KEY" 2>/dev/null | grep "^ssh-" > "$SSH_PUBKEY"
    fi
}

setup_ssh_keys() {
    local ip="$1"
    local password="$2"
    ensure_ssh_key

    local pubkey=$(cat "$SSH_PUBKEY")
    local ssh_cmd="mkdir -p /etc/dropbear && echo '$pubkey' >> /etc/dropbear/authorized_keys && chmod 600 /etc/dropbear/authorized_keys && sort -u /etc/dropbear/authorized_keys -o /etc/dropbear/authorized_keys"

    if [ -n "$password" ]; then
        echo "[*] Installing SSH key on $ip (using stored password)..."
        if command -v sshpass >/dev/null 2>&1; then
            sshpass -p "$password" dbclient -y root@"$ip" "$ssh_cmd" 2>/dev/null
        else
            echo "    Installing sshpass..."
            ensure_pkg_local sshpass sshpass gcs
            if command -v sshpass >/dev/null 2>&1; then
                sshpass -p "$password" dbclient -y root@"$ip" "$ssh_cmd" 2>/dev/null
            else
                echo "    ERROR: sshpass not available. Please install SSH key manually."
                return 1
            fi
        fi
    else
        echo "[*] Installing SSH key on $ip (enter password once)..."
        dbclient -y root@"$ip" "$ssh_cmd"
    fi

    sleep 1
    local verify=$(dbclient -i "$SSH_KEY" -y root@"$ip" "echo keyauth_ok" </dev/null 2>/dev/null)
    if [ "$verify" = "keyauth_ok" ]; then
        echo "    SSH key installed successfully."
    else
        echo "    WARNING: Key verification inconclusive. Continuing..."
    fi
}

ssh_aircraft() {
    local ip="$1"; shift
    dbclient -i "$SSH_KEY" -y root@"$ip" "$@"
}

#############################################
# HEALTH CHECK FUNCTIONS
#############################################
check_local_health() {
    # Only check services that have been configured (init scripts exist)
    # If setup hasn't been run, there's nothing to check
    [ -f /etc/init.d/kcptun-server ] || [ -f /etc/init.d/kcptun-client ] || [ -f /etc/init.d/l2tap ] || return 0

    local issues=""
    is_tailscale_ready || issues="${issues}tailscale_down,"

    if [ -f /etc/init.d/kcptun-server ]; then
        pgrep -f kcptun-server > /dev/null 2>&1 || issues="${issues}kcptun_down,"
    elif [ -f /etc/init.d/kcptun-client ]; then
        pgrep -f kcptun-client > /dev/null 2>&1 || issues="${issues}kcptun_down,"
    fi

    [ -f /etc/init.d/l2tap ] && ! pgrep -x l2tap > /dev/null 2>&1 && issues="${issues}l2tap_down,"
    [ -f /etc/init.d/l2tap ] && ! ip link show l2bridge > /dev/null 2>&1 && issues="${issues}interface_missing,"

    [ -n "$issues" ] && { echo "${issues%,}"; return 1; }
    return 0
}

record_health() {
    cat > "$HEALTH_FILE" << EOF
LAST_CHECK="$(date '+%Y-%m-%d %H:%M:%S')"
STATUS="$1"
DETAILS="$2"
EOF
}

#############################################
# SERVICE MANAGEMENT
#############################################
start_local_services() {
    log_info "Starting local services..."

    if ! wait_for_tailscale; then
        log_error "Cannot start - Tailscale not available"
        return 1
    fi

    local GCS_IP=$(get_local_tailscale_ip)

    # Update kcptun config with current IP
    if [ -f /etc/kcptun/server.json ]; then
        sed -i "s|\"listen\": \"[^\"]*:|\"listen\": \"$GCS_IP:|g" /etc/kcptun/server.json
    fi

    /etc/init.d/kcptun-server start 2>/dev/null || true
    sleep $KCPTUN_SETTLE_TIME

    if ! pgrep -f kcptun-server > /dev/null 2>&1; then
        log_error "kcptun-server failed to start"
        return 1
    fi

    /etc/init.d/l2tap start 2>/dev/null || true
    sleep 2

    log_info "Local services started"
    return 0
}

start_aircraft_services() {
    local AIRCRAFT_IP="$1"
    local GCS_IP=$(get_local_tailscale_ip)

    log_info "Starting aircraft services on $AIRCRAFT_IP..."

    check_aircraft_reachable "$AIRCRAFT_IP" || { log_warn "Aircraft unreachable"; return 1; }

    ssh_aircraft "$AIRCRAFT_IP" "
        [ -f /etc/kcptun/client.json ] && sed -i 's|\"remoteaddr\": \"[^\"]*:|\"remoteaddr\": \"$GCS_IP:|g' /etc/kcptun/client.json
        /etc/init.d/kcptun-client start 2>/dev/null || true
        sleep 3
        /etc/init.d/l2tap start 2>/dev/null || true
    " 2>/dev/null || { log_warn "Could not start aircraft services"; return 1; }

    log_info "Aircraft services started"
}

stop_local_services() {
    log_info "Stopping local services..."
    /etc/init.d/l2tap stop 2>/dev/null || true
    /etc/init.d/kcptun-server stop 2>/dev/null || true
    # Cleanup in case l2tap-down didn't run
    nft delete table bridge l2bridge_filter 2>/dev/null || true
    ip link set l2bridge nomaster 2>/dev/null || true
    ip link del l2bridge 2>/dev/null || true
    iptables -D OUTPUT -o br-lan -p udp --dport 41641 -j DROP 2>/dev/null || true
    iptables -D OUTPUT -o br-lan -p udp --sport 41641 -j DROP 2>/dev/null || true
    iptables -D FORWARD -i l2bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
