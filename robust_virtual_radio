#############################################
# PROFILE MANAGEMENT
# Single source of truth — api.cgi delegates here
#############################################
cmd_profile() {
    local subcmd="$1"; shift 2>/dev/null || true
    local aircraft_file="/etc/rvr/aircraft.json"

    case "$subcmd" in
        list)
            mkdir -p /etc/rvr
            [ -f "$aircraft_file" ] || printf '{\n  "version": 1,\n  "active": "",\n  "profiles": {}\n}\n' > "$aircraft_file"
            cat "$aircraft_file"
            ;;
        add)
            local id="$1" name="$2" ip="$3" password="${4:-}"
            [ -z "$id" ] || [ -z "$name" ] || [ -z "$ip" ] && { echo "Usage: rvr profile add <id> <name> <ip> [password]"; exit 1; }
            save_aircraft_profile "$name" "$ip" "$id"
            # Update password if provided
            if [ -n "$password" ] && [ -f "$aircraft_file" ]; then
                local safe_pass=$(printf '%s' "$password" | sed 's/[&/\]/\\&/g')
                # Find the profile and update password
                awk -v id="$id" -v pass="$safe_pass" '
                    /"'"$id"'"/ { found=1 }
                    found && /"ssh_password":/ {
                        sub(/"ssh_password":[[:space:]]*"[^"]*"/, "\"ssh_password\": \"" pass "\"")
                        found=0
                    }
                    { print }
                ' "$aircraft_file" > "${aircraft_file}.tmp" && mv "${aircraft_file}.tmp" "$aircraft_file"
            fi
            echo "{\"success\": true, \"id\": \"$id\"}"
            ;;
        update)
            local id="$1"; shift 2>/dev/null || true
            [ -z "$id" ] && { echo "Usage: rvr profile update <id> [--name X] [--ip X] [--password X]"; exit 1; }
            [ -f "$aircraft_file" ] || { echo "ERROR: No profiles"; exit 1; }
            local new_name="" new_ip="" new_pass=""
            while [ $# -gt 0 ]; do
                case "$1" in
                    --name) new_name="$2"; shift 2 ;;
                    --ip) new_ip="$2"; shift 2 ;;
                    --password) new_pass="$2"; shift 2 ;;
                    *) shift ;;
                esac
            done
            # Update fields via sed
            if [ -n "$new_name" ]; then
                awk -v id="$id" -v val="$new_name" 'BEGIN{f=0} /"'"$id"'"/{f=1} f&&/"name":/{sub(/"name":[[:space:]]*"[^"]*"/,"\"name\": \""val"\"");f=0} {print}' "$aircraft_file" > "${aircraft_file}.tmp" && mv "${aircraft_file}.tmp" "$aircraft_file"
            fi
            if [ -n "$new_ip" ]; then
                awk -v id="$id" -v val="$new_ip" 'BEGIN{f=0} /"'"$id"'"/{f=1} f&&/"tailscale_ip":/{sub(/"tailscale_ip":[[:space:]]*"[^"]*"/,"\"tailscale_ip\": \""val"\"");f=0} {print}' "$aircraft_file" > "${aircraft_file}.tmp" && mv "${aircraft_file}.tmp" "$aircraft_file"
            fi
            if [ -n "$new_pass" ]; then
                awk -v id="$id" -v val="$new_pass" 'BEGIN{f=0} /"'"$id"'"/{f=1} f&&/"ssh_password":/{sub(/"ssh_password":[[:space:]]*"[^"]*"/,"\"ssh_password\": \""val"\"");f=0} {print}' "$aircraft_file" > "${aircraft_file}.tmp" && mv "${aircraft_file}.tmp" "$aircraft_file"
            fi
            echo "{\"success\": true}"
            ;;
        delete)
            local id="$1"
            [ -z "$id" ] && { echo "Usage: rvr profile delete <id>"; exit 1; }
            [ -f "$aircraft_file" ] || { echo "ERROR: No profiles"; exit 1; }
            # Extract all profiles except the one to delete, rebuild JSON
            local tmp_profiles=$(mktemp)
            awk '
            /"[a-zA-Z0-9_-]+":[[:space:]]*\{/ {
                pid = $0; sub(/^[^"]*"/, "", pid); sub(/".*/, "", pid)
                if (pid != "profiles") current_id = pid
            }
            current_id && /"name":/ { val=$0; sub(/.*"name":[[:space:]]*"/, "", val); sub(/".*/, "", val); p_name[current_id]=val }
            current_id && /"tailscale_ip":/ { val=$0; sub(/.*"tailscale_ip":[[:space:]]*"/, "", val); sub(/".*/, "", val); p_ip[current_id]=val }
            current_id && /"ssh_password":/ { val=$0; sub(/.*"ssh_password":[[:space:]]*"/, "", val); sub(/".*/, "", val); p_pass[current_id]=val }
            current_id && /"created":/ { val=$0; sub(/.*"created":[[:space:]]*"/, "", val); sub(/".*/, "", val); p_created[current_id]=val }
            current_id && /"last_used":/ {
                val=$0; sub(/.*"last_used":[[:space:]]*"/, "", val); sub(/".*/, "", val)
                p_last[current_id]=val
                if (current_id != id) print current_id "|" p_name[current_id] "|" p_ip[current_id] "|" p_pass[current_id] "|" p_created[current_id] "|" p_last[current_id]
            }
            ' id="$id" "$aircraft_file" > "$tmp_profiles"

            local active=$(sed -n 's/.*"active"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$aircraft_file" | head -1)
            [ "$active" = "$id" ] && active=""

            printf '{\n  "version": 1,\n  "active": "%s",\n  "profiles": {\n' "$active" > "$aircraft_file"
            local first=1
            while IFS='|' read -r pid pname pip ppass pcreated plast; do
                [ -z "$pid" ] && continue
                [ $first -eq 0 ] && printf ',\n' >> "$aircraft_file"
                printf '    "%s": {\n      "name": "%s",\n      "tailscale_ip": "%s",\n      "ssh_password": "%s",\n      "created": "%s",\n      "last_used": "%s"\n    }' \
                    "$pid" "$pname" "$pip" "$ppass" "$pcreated" "$plast" >> "$aircraft_file"
                first=0
            done < "$tmp_profiles"
            printf '\n  }\n}\n' >> "$aircraft_file"
            rm -f "$tmp_profiles"

            # Clear state file if this was the active aircraft
            if [ -f "$STATE_FILE" ]; then
                . "$STATE_FILE"
                local current_ip
                current_ip=$(awk -v id="$id" '/"'"$id"'"/{f=1} f&&/"tailscale_ip":/{gsub(/.*"tailscale_ip":[[:space:]]*"/,"");gsub(/".*/,"");print;exit}' "$aircraft_file" 2>/dev/null)
                [ "${AIRCRAFT_IP:-}" = "$current_ip" ] && rm -f "$STATE_FILE"
            fi
            echo "{\"success\": true}"
            ;;
        set-active)
            local id="$1"
            [ -z "$id" ] && { echo "Usage: rvr profile set-active <id>"; exit 1; }
            [ -f "$aircraft_file" ] || { echo "ERROR: No profiles"; exit 1; }
            sed -i "s/\"active\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/\"active\": \"$id\"/" "$aircraft_file"
            # Also update /etc/rvr.conf state file
            local ip=$(awk -v id="$id" '/"'"$id"'"/{f=1} f&&/"tailscale_ip":/{gsub(/.*"tailscale_ip":[[:space:]]*"/,"");gsub(/".*/,"");print;exit}' "$aircraft_file")
            [ -n "$ip" ] && echo "AIRCRAFT_IP=\"$ip\"" > "$STATE_FILE"
            echo "{\"success\": true}"
            ;;
        *)
            echo "Usage: rvr profile <list|add|update|delete|set-active> [args]"
            exit 1
            ;;
    esac
}

# Unbind aircraft — stop services, clean up aircraft, delete profile
# Used by WebUI unbind action (delegates here instead of reimplementing)
cmd_unbind() {
    local input="$1"
    [ -z "$input" ] && { echo "Usage: rvr unbind <name|ip|id>"; exit 1; }
    local AIRCRAFT_IP=$(get_aircraft_ip "$input")

    echo "[*] Stopping bridge services..."
    stop_local_services
    [ -n "$AIRCRAFT_IP" ] && stop_aircraft_services "$AIRCRAFT_IP" 2>/dev/null || true

    # Clean up aircraft config if reachable
    if [ -n "$AIRCRAFT_IP" ] && check_aircraft_reachable "$AIRCRAFT_IP" 2>/dev/null; then
        echo "[*] Cleaning up aircraft ($AIRCRAFT_IP)..."
        ssh_aircraft "$AIRCRAFT_IP" '
            /etc/init.d/kcptun-client stop 2>/dev/null || true
            /etc/init.d/tap2tcp stop 2>/dev/null || true
            [ -x /etc/rvr/tap2tcp-down ] && /etc/rvr/tap2tcp-down 2>/dev/null || true
            /etc/init.d/kcptun-client disable 2>/dev/null || true
            /etc/init.d/tap2tcp disable 2>/dev/null || true
            rm -f /etc/init.d/kcptun-client /etc/init.d/tap2tcp
            rm -rf /etc/rvr
            rm -f /etc/kcptun/client.json
            rmdir /etc/kcptun 2>/dev/null || true
            rm -f /usr/bin/tap2tcp
            ip link set br-lan type bridge stp_state 0 2>/dev/null || true
            rm -rf /tmp/rvr /tmp/rvr.* /tmp/rvr-* /tmp/tap2tcp*
        ' 2>/dev/null || log_warn "Aircraft cleanup failed (may need manual cleanup)"
    fi

    # Delete the profile
    local profile_id="$input"
    # If input was an IP, resolve to profile ID
    if echo "$input" | grep -qE '^100\.'; then
        profile_id=$(awk -v ip="$input" '
            /"[a-zA-Z0-9_-]+"[[:space:]]*:[[:space:]]*\{/ {
                id=$0; sub(/^[^"]*"/, "", id); sub(/".*/, "", id)
                if (id != "profiles") current_id=id
            }
            current_id && /"tailscale_ip"/ && index($0, ip) { print current_id; exit }
        ' /etc/rvr/aircraft.json 2>/dev/null)
    fi
    [ -n "$profile_id" ] && cmd_profile delete "$profile_id" > /dev/null 2>&1

    rm -f "$STATE_FILE"
    echo "{\"success\": true}"
}

cmd_remove_aircraft() {
    local input="$1"
    [ -z "$input" ] && { echo "Usage: rvr remove-aircraft <name|ip>"; exit 1; }
    local AIRCRAFT_IP=$(get_aircraft_ip "$input")
    [ -z "$AIRCRAFT_IP" ] && { echo "ERROR: Could not resolve '$input' to an aircraft IP"; exit 1; }

    echo ""
    echo "This will remove the L2 bridge from aircraft $AIRCRAFT_IP"
    echo "and delete its profile. GCS will remain intact."
    echo ""
    printf "Continue? [y/N] "
    read confirm
    [ "$confirm" != "y" ] && [ "$confirm" != "Y" ] && { echo "Aborted."; exit 0; }

    echo ""

    echo "[*] Stopping bridge services..."
    stop_local_services
    stop_aircraft_services "$AIRCRAFT_IP" 2>/dev/null || true

    if check_aircraft_reachable "$AIRCRAFT_IP" 2>/dev/null; then
        echo "[*] Uninstalling from aircraft ($AIRCRAFT_IP)..."
        ssh_aircraft "$AIRCRAFT_IP" '
            /etc/init.d/kcptun-client stop 2>/dev/null || true
            /etc/init.d/tap2tcp stop 2>/dev/null || true
            [ -x /etc/rvr/tap2tcp-down ] && /etc/rvr/tap2tcp-down 2>/dev/null || true
            /etc/init.d/kcptun-client disable 2>/dev/null || true
            /etc/init.d/tap2tcp disable 2>/dev/null || true
            rm -f /etc/init.d/kcptun-client /etc/init.d/tap2tcp
            rm -rf /etc/rvr
            rm -f /etc/kcptun/client.json
            rmdir /etc/kcptun 2>/dev/null || true
            rm -f /usr/bin/tap2tcp
            ip link set br-lan type bridge stp_state 0 2>/dev/null || true
            rm -rf /tmp/rvr /tmp/rvr.* /tmp/rvr-* /tmp/tap2tcp*
        ' 2>/dev/null || log_warn "Aircraft cleanup failed (may need manual cleanup)"
    else
        echo "[!] Aircraft $AIRCRAFT_IP unreachable - skipping remote cleanup"
    fi

    # Remove profile from aircraft.json
    local aircraft_file="/etc/rvr/aircraft.json"
    if [ -f "$aircraft_file" ]; then
        local profile_id=$(awk -v ip="$AIRCRAFT_IP" '
            /"[a-zA-Z0-9_-]+"[[:space:]]*:[[:space:]]*\{/ {
                id=$0; sub(/^[^"]*"/, "", id); sub(/".*/, "", id)
                if (id != "profiles") current_id=id
            }
            current_id && /"tailscale_ip"/ && index($0, ip) {
                print current_id; exit
            }
        ' "$aircraft_file")
        if [ -n "$profile_id" ]; then
            echo "[*] Removing profile '$profile_id' from aircraft.json..."
            local active=$(sed -n 's/.*"active"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$aircraft_file" | head -1)
            [ "$active" = "$profile_id" ] && sed -i "s/\"active\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/\"active\": \"\"/" "$aircraft_file"
        fi
    fi

    if [ -f "$STATE_FILE" ]; then
        . "$STATE_FILE"
        [ "${AIRCRAFT_IP:-}" = "$AIRCRAFT_IP" ] && rm -f "$STATE_FILE"
    fi

    echo ""
    echo "Aircraft $AIRCRAFT_IP removed. GCS is still operational."
    echo "Use 'rvr add <ip>' to connect a different aircraft."
}

cmd_uninstall() {
    local script_dir=$(dirname "$(readlink -f "$0")")
    local do_aircraft=0

    # Parse flags
    while [ $# -gt 0 ]; do
        case "$1" in
            --aircraft) do_aircraft=1; shift ;;
            *) shift ;;
        esac
    done

    echo ""
    echo "This will completely remove RVR and all configuration."
    echo ""
    printf "Continue? [y/N] "
    read confirm
    [ "$confirm" != "y" ] && [ "$confirm" != "Y" ] && { echo "Aborted."; exit 0; }
    echo ""

    # Phase 1: Isolate from uhttpd — remove config, restart, wait healthy.
    #          Uses cmd_webui_remove which handles uhttpd + firewall + files.
    #          After this, :8081 is gone. No more CGI polls can run.
    echo "[1/6] Removing web UI..."
    cmd_webui_remove 2>/dev/null || true

    # Phase 2: Stop RVR services top-down (tap2tcp → kcptun → bridge → STP)
    echo "[2/6] Stopping services..."
    stop_local_services 2>/dev/null || true

    # Phase 3: Remove cron/boot entries
    echo "[3/6] Removing watchdog..."
    cmd_watchdog_remove 2>/dev/null || true

    # Phase 4: Remove config and init scripts
    echo "[4/6] Removing configuration..."
    /etc/init.d/kcptun-server disable 2>/dev/null || true
    /etc/init.d/tap2tcp disable 2>/dev/null || true
    rm -f /etc/init.d/kcptun-server /etc/init.d/tap2tcp
    rm -rf /etc/rvr
    rm -f /etc/kcptun/server.json
    rmdir /etc/kcptun 2>/dev/null || true
    rm -f "$STATE_FILE" "$HEALTH_FILE"
    rm -f "$TAP2TCP_BINARY"

    # Phase 5: Remove packages top-down (applications → runtimes → libraries)
    echo "[5/6] Removing packages..."
    # pip packages first (while python3 still exists)
    if command -v python3 >/dev/null 2>&1 && python3 -m pip --version >/dev/null 2>&1; then
        python3 -m pip uninstall -y grpcio grpcio-reflection protobuf yagrc typing-extensions pip setuptools wheel 2>/dev/null || true
    fi
    # opkg: applications first, then runtimes, then libraries
    for pkg in \
        kcptun-server kcptun-client sshpass \
        kcptun-config git-http git \
        python3 \
        python3-asyncio python3-cgi python3-cgitb python3-codecs python3-ctypes \
        python3-dbm python3-decimal python3-distutils python3-email python3-logging \
        python3-lzma python3-multiprocessing python3-ncurses python3-openssl \
        python3-pydoc python3-readline python3-sqlite3 python3-unittest python3-urllib \
        python3-uuid python3-xml python3-light python3-base \
        libpython3-3.11 libffi libgdbm \
    ; do
        opkg remove "$pkg" 2>/dev/null || true
    done

    # Phase 6: Remove files
    echo "[6/6] Removing files..."
    rm -f /usr/bin/rvr
    rm -rf /tmp/rvr /tmp/rvr.* /tmp/rvr-* /tmp/tap2tcp*
    [ -d "$script_dir" ] && rm -rf "$script_dir"

    # Aircraft cleanup only if explicitly requested
    if [ $do_aircraft -eq 1 ]; then
        local AIRCRAFT_IP=$(get_aircraft_ip 2>/dev/null)
        if [ -n "$AIRCRAFT_IP" ] && check_aircraft_reachable "$AIRCRAFT_IP" 2>/dev/null; then
            echo "[*] Cleaning up aircraft ($AIRCRAFT_IP)..."
            ssh_aircraft "$AIRCRAFT_IP" '
                /etc/init.d/tap2tcp stop 2>/dev/null || true
                /etc/init.d/kcptun-client stop 2>/dev/null || true
                [ -x /etc/rvr/tap2tcp-down ] && /etc/rvr/tap2tcp-down 2>/dev/null || true
                /etc/init.d/kcptun-client disable 2>/dev/null || true
                /etc/init.d/tap2tcp disable 2>/dev/null || true
                rm -f /etc/init.d/kcptun-client /etc/init.d/tap2tcp
                rm -rf /etc/rvr
                rm -f /etc/kcptun/client.json
                rmdir /etc/kcptun 2>/dev/null || true
                rm -f /usr/bin/tap2tcp
                ip link set br-lan type bridge stp_state 0 2>/dev/null || true
                rm -rf /tmp/rvr /tmp/rvr.* /tmp/rvr-* /tmp/tap2tcp*
            ' 2>/dev/null || log_warn "Aircraft cleanup failed"
        else
            echo "[!] Aircraft unreachable — skipping"
        fi
    fi

    echo ""
    echo "=========================================="
    echo "  RVR fully uninstalled."
    echo "=========================================="
}

#############################################
# WEB UI INSTALL/REMOVE
#############################################
WEBUI_ROOT="/www/rvr"
WEBUI_CONFIG_DIR="/etc/rvr"
WEBUI_PORT="8081"

cmd_webui_install() {
    log_info "Installing RVR Web UI..."

    mkdir -p "$WEBUI_ROOT/cgi-bin"
    mkdir -p "$WEBUI_CONFIG_DIR"
    mkdir -p /tmp/rvr

    local script_dir=$(dirname "$(readlink -f "$0")")
    local src_www="$script_dir/www"

    if [ -d "$src_www" ]; then
        log_info "Installing from local source: $src_www"
        cp "$src_www/index.html" "$WEBUI_ROOT/"
        if [ -d "$src_www/assets" ]; then
            rm -rf "$WEBUI_ROOT/assets" && mkdir -p "$WEBUI_ROOT/assets"
            cp -r "$src_www/assets/"* "$WEBUI_ROOT/assets/"
        fi
        cp "$src_www/cgi-bin/"*.cgi "$src_www/cgi-bin/"*.py "$WEBUI_ROOT/cgi-bin/"
        chmod +x "$WEBUI_ROOT/cgi-bin/"*.cgi "$WEBUI_ROOT/cgi-bin/"*.py 2>/dev/null
    else
        log_error "Web UI source files not found at $src_www"
        exit 1
    fi

    chmod +x "$WEBUI_ROOT/cgi-bin/"*.cgi

    local git_hash=$(cd "$script_dir" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    echo "$git_hash" > "$WEBUI_CONFIG_DIR/version"

    local git_remote=$(cd "$script_dir" && git config --get remote.origin.url 2>/dev/null || echo "")
    local repo_path=$(echo "$git_remote" | sed 's|.*github.com[:/]||; s|\.git$||')
    if [ -n "$repo_path" ]; then
        echo "$repo_path" > "$WEBUI_CONFIG_DIR/repo"
    fi

    if [ ! -f "$WEBUI_CONFIG_DIR/aircraft.json" ]; then
        printf '{\n  "version": 1,\n  "active": "",\n  "profiles": {}\n}\n' > "$WEBUI_CONFIG_DIR/aircraft.json"
    fi

    log_info "Configuring uhttpd on port $WEBUI_PORT..."

    if uci get uhttpd.rvr >/dev/null 2>&1; then
        log_info "Updating existing uhttpd configuration..."
    else
        log_info "Creating new uhttpd configuration..."
        uci set uhttpd.rvr=uhttpd
    fi

    uci set uhttpd.rvr.listen_http="0.0.0.0:$WEBUI_PORT"
    uci set uhttpd.rvr.home="$WEBUI_ROOT"
    uci set uhttpd.rvr.cgi_prefix='/cgi-bin'
    uci set uhttpd.rvr.script_timeout='300'
    uci set uhttpd.rvr.no_symlinks='0'
    uci set uhttpd.rvr.no_dirlists='1'
    uci set uhttpd.rvr.rfc1918_filter='0'
    uci commit uhttpd

    /etc/init.d/uhttpd restart

    if command -v fw4 >/dev/null 2>&1 || [ -f /etc/config/firewall ]; then
        log_info "Configuring firewall for port $WEBUI_PORT..."
        if ! uci get firewall.rvr_webui >/dev/null 2>&1; then
            uci set firewall.rvr_webui=rule
            uci set firewall.rvr_webui.name='Allow-RVR-WebUI'
            uci set firewall.rvr_webui.src='lan'
            uci set firewall.rvr_webui.proto='tcp'
            uci set firewall.rvr_webui.dest_port="$WEBUI_PORT"
            uci set firewall.rvr_webui.target='ACCEPT'
            uci commit firewall
            /etc/init.d/firewall reload 2>/dev/null || true
        fi
    fi

    if ! crontab -l 2>/dev/null | grep -q "rvr-watchdog"; then
        cmd_watchdog_install
    fi

    do_health_check "$(get_aircraft_ip)" >/dev/null 2>&1 || true

    echo ""
    echo "========================================="
    echo "  RVR Web UI Installed"
    echo "========================================="
    echo ""
    echo "  Access the control panel at:"
    echo "  http://$(get_tailscale_ip_nowait 2>/dev/null || echo '<router-ip>'):$WEBUI_PORT"
    echo ""
    local lan_ip=$(ip -4 addr show br-lan 2>/dev/null | awk '/inet / {print $2}' | cut -d'/' -f1 | head -1)
    [ -n "$lan_ip" ] && echo "  Or from LAN: http://$lan_ip:$WEBUI_PORT"
    echo ""
}

cmd_webui_remove() {
    log_info "Removing RVR Web UI..."

    # 1. Remove uhttpd config (no files deleted yet)
    if uci get uhttpd.rvr >/dev/null 2>&1; then
        uci delete uhttpd.rvr
        uci commit uhttpd
    fi

    # 2. Restart uhttpd — comes back clean, :8081 gone, GL admin unaffected
    /etc/init.d/uhttpd restart 2>/dev/null || true

    # 3. Wait for uhttpd to be running
    local i=0
    while [ $i -lt 10 ]; do
        /etc/init.d/uhttpd running 2>/dev/null && break
        sleep 1
        i=$((i + 1))
    done

    # 4. Kill orphaned CGI children (starlink_outages.py imports grpcio native
    #    lib with 10s gRPC timeout — if pip removes grpcio while this process
    #    is still running, the segfault crashes the GL-BE3600)
    pkill -f "python3.*starlink_outages" 2>/dev/null || true
    pkill -f "starlink_outages.py" 2>/dev/null || true
    sleep 1

    # 5. Remove firewall rule from running nftables + UCI
    if uci get firewall.rvr_webui >/dev/null 2>&1; then
        local handle=$(nft -an list chain inet fw4 input_lan 2>/dev/null | grep "Allow-RVR-WebUI" | grep -o 'handle [0-9]*' | awk '{print $2}')
        [ -n "$handle" ] && nft delete rule inet fw4 input_lan handle "$handle" 2>/dev/null || true
        uci delete firewall.rvr_webui
        uci commit firewall
    fi

    # 5. Remove web UI files
    rm -rf "$WEBUI_ROOT"
    log_info "Aircraft profiles preserved in $WEBUI_CONFIG_DIR"

    echo "Web UI removed."
}

#############################################
# UPDATE
#############################################
cmd_update() {
    local repo_dir=""
    local script_path=$(readlink -f "$0" 2>/dev/null || echo "$0")
    local script_dir=$(dirname "$script_path")
    if [ -d "$script_dir/.git" ]; then
        repo_dir="$script_dir"
    elif [ -d "/root/RVR_v0.4/.git" ]; then
        repo_dir="/root/RVR_v0.4"
    fi

    if [ -z "$repo_dir" ]; then
        log_error "Cannot find git repository"
        exit 1
    fi

    # Parse --branch argument (default: stored branch or main)
    local branch="main"
    [ -f "$WEBUI_CONFIG_DIR/branch" ] && branch=$(cat "$WEBUI_CONFIG_DIR/branch")
    while [ $# -gt 0 ]; do
        case "$1" in
            --branch) branch="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    # Pre-flight space check — abort if < 30MB free on /overlay
    local free_kb=$(df /overlay 2>/dev/null | tail -1 | awk '{print $4}')
    if [ "${free_kb:-999999}" -lt 30720 ]; then
        log_error "Not enough space for update (${free_kb}KB free, need 30MB)"
        echo "  Free /overlay space: ${free_kb}KB — minimum 30MB required"
        echo "  Run 'rvr capture stop' and delete old captures to free space"
        exit 1
    fi

    echo "Updating RVR from GitHub..."
    echo "  Repository: $repo_dir"
    echo "  Branch: $branch"

    local old_hash=$(cd "$repo_dir" && git rev-parse --short HEAD 2>/dev/null)
    echo "  Current version: $old_hash"

    cd "$repo_dir"
    # Shallow fetch — only latest commit, saves ~90% storage vs full history
    git fetch --depth=1 origin "$branch" 2>&1 || { log_error "Failed to fetch branch '$branch'"; exit 1; }

    local new_hash=$(git rev-parse --short "origin/$branch" 2>/dev/null)
    if [ "$old_hash" = "$new_hash" ] && [ "$(cat "$WEBUI_CONFIG_DIR/branch" 2>/dev/null)" = "$branch" ]; then
        echo "  Already up to date ($old_hash on $branch)"
        rm -f /tmp/rvr-latest-version
        return 0
    fi

    git reset --hard "origin/$branch" 2>&1 || { log_error "Failed to apply updates"; exit 1; }

    # Re-point symlink before anything else (handles script renames across updates)
    local script_name
    script_name=$(basename "$(readlink -f "$0" 2>/dev/null || echo "$0")")
    if [ -f "$repo_dir/$script_name" ]; then
        chmod +x "$repo_dir/$script_name"
        ln -sf "$repo_dir/$script_name" /usr/bin/rvr
    fi
    chmod +x "$repo_dir/www/cgi-bin/"*.cgi 2>/dev/null

    # Clean stale git objects to reclaim storage
    git reflog expire --expire=now --all 2>/dev/null
    git gc --prune=all -q 2>/dev/null

    # Update tap2tcp binary if new one available
    if [ -f "$repo_dir/packages/common/tap2tcp-aarch64" ]; then
        cp "$repo_dir/packages/common/tap2tcp-aarch64" "$TAP2TCP_BINARY"
        chmod +x "$TAP2TCP_BINARY"
        log_info "Updated tap2tcp binary"
    fi

    echo "  Updated: $old_hash -> $new_hash ($branch)"

    if [ -d "$WEBUI_ROOT" ]; then
        log_info "Updating web UI files..."
        local src_www="$repo_dir/www"
        if [ -d "$src_www" ]; then
            cp "$src_www/index.html" "$WEBUI_ROOT/"
            # Clean old assets before copying new — prevents stale chunk accumulation
            if [ -d "$src_www/assets" ]; then
                rm -rf "$WEBUI_ROOT/assets"
                mkdir -p "$WEBUI_ROOT/assets"
                cp -r "$src_www/assets/"* "$WEBUI_ROOT/assets/"
            fi
            cp "$src_www/cgi-bin/"*.cgi "$src_www/cgi-bin/"*.py "$WEBUI_ROOT/cgi-bin/"
            chmod +x "$WEBUI_ROOT/cgi-bin/"*.cgi "$WEBUI_ROOT/cgi-bin/"*.py 2>/dev/null
            mkdir -p "$WEBUI_CONFIG_DIR"
            echo "$new_hash" > "$WEBUI_CONFIG_DIR/version"
            echo "$branch" > "$WEBUI_CONFIG_DIR/branch"
            rm -f /tmp/rvr-latest-version
            log_info "Web UI updated"
        fi
    else
        # No web UI installed — still save version/branch
        mkdir -p "$WEBUI_CONFIG_DIR"
        echo "$new_hash" > "$WEBUI_CONFIG_DIR/version"
        echo "$branch" > "$WEBUI_CONFIG_DIR/branch"
    fi

    local AIRCRAFT_IP=$(get_aircraft_ip 2>/dev/null)
    if [ -n "$AIRCRAFT_IP" ] && pgrep tap2tcp >/dev/null 2>&1; then
        log_info "Restarting bridge to apply updates..."
        if ! cmd_restart "$AIRCRAFT_IP"; then
            log_warn "Bridge restart failed — may need manual restart"
        fi
    fi

    echo ""
    echo "Update complete. ($branch:$new_hash)"
}

#############################################
# BRANCHES — list available remote branches
